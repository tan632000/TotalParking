<script>
    // Live filter alarm list
    function filterAlarms() {
        const query = document.getElementById("alarmSearchInput").value.toLowerCase();
        const type = document.getElementById("filterType").value;
        const severity = document.getElementById("filterSeverity").value;
        
        const rows = document.querySelectorAll(".alarm-row");
        
        rows.forEach(row => {
            const textMatch = row.innerText.toLowerCase().includes(query);
            const typeMatch = (type === "all") || (row.getAttribute("data-type") === type);
            const severityMatch = (severity === "all") || (row.getAttribute("data-severity") === severity);
            
            if (textMatch && typeMatch && severityMatch) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

    // Acknowledge alarm action
    function acknowledgeAlarm(btn, operatorName) {
        const row = btn.closest("tr");
        
        // 1. Update text/style for Acknowledge column
        const statusBadge = row.querySelector(".status-badge");
        statusBadge.innerText = "Đã xác nhận";
        statusBadge.className = "status-badge text-[10px] font-bold text-slate-400";
        
        // 2. Set operator name
        const operatorCell = row.querySelector(".ack-operator");
        operatorCell.innerText = operatorName;
        operatorCell.className = "ack-operator px-3 py-3 text-slate-300";
        
        // 3. Remove action button
        const actionCell = btn.parentNode;
        actionCell.innerHTML = '<span class="text-slate-500 text-[10px] font-bold">—</span>';
        
        // 4. Toast notification
        alert("Đã xác nhận xử lý cảnh báo thành công cho tài khoản " + operatorName + "!");
    }
</script>