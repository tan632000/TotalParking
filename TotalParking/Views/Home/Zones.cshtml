@{
    Layout = "~/Views/Shared/_ScadaLayout.cshtml";
}

<div class="flex-1 overflow-y-auto p-6 space-y-6" style="background: rgb(15, 23, 42); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="flex justify-between items-center pb-4 border-b border-slate-800">
        <div>
            <h1 class="text-2xl font-bold text-white tracking-tight">Sơ đồ giám sát phân khu (Zones Map)</h1>
            <p class="text-slate-400 text-sm mt-1">Rê chuột vào từng phân khu để xem viền nổi bật, click để xem sơ đồ ô đỗ chi tiết.</p>
        </div>
    </div>

    <!-- Interactive Map Container -->
    <div class="relative w-full overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50 shadow-2xl p-2 flex justify-center items-center">
        <!-- aspect ratio wrapper to maintain 1016x781 dimensions -->
        <div class="relative w-full max-w-5xl" style="aspect-ratio: 1016 / 781;">
            <!-- Background Image -->
            <img src="@Url.Content("~/Images/zones_map.jpeg")" alt="Parking Zones Map" class="w-full h-full object-contain select-none" />

            <!-- SVG Overlay -->
            <svg class="absolute top-0 left-0 w-full h-full pointer-events-auto" viewBox="0 0 1016 781" xmlns="http://www.w3.org/2000/svg">
                <!-- Zone 3 (Top Left, Orange) -->
                <a href="@Url.Action("Zones", "Home", new { id = 3 })" class="zone-link">
                    <polygon points="57,152 185,46 343,45 308,248 278,293 308,390" class="zone-polygon zone-3" />
                </a>

                <!-- Zone 4 (Top Middle, Purple) -->
                <a href="@Url.Action("Zones", "Home", new { id = 4 })" class="zone-link">
                    <polygon points="343,45 526,45 526,390 412,390 412,390 372,390 372,390 308,390 278,293 308,248" class="zone-polygon zone-4" />
                </a>

                <!-- Zone 5 (Top Right, Cyan/Blue) -->
                <a href="@Url.Action("Zones", "Home", new { id = 5 })" class="zone-link">
                    <polygon points="526,45 923,46 923,235 718,223 632,198 526,211" class="zone-polygon zone-5" />
                </a>

                <!-- Zone 6 (Middle Right, Green) -->
                <a href="@Url.Action("Zones", "Home", new { id = 6 })" class="zone-link">
                    <polygon points="526,211 632,198 718,223 923,235 923,410 602,410 602,380 573,380" class="zone-polygon zone-6" />
                </a>

                <!-- Zone 2 (Bottom Middle, Grey) -->
                <a href="@Url.Action("Zones", "Home", new { id = 2 })" class="zone-link">
                    <polygon points="308,390 602,390 602,510 573,510 573,630" class="zone-polygon zone-2" />
                </a>

                <!-- Zone 1 (Bottom Right, Yellow) -->
                <a href="@Url.Action("Zones", "Home", new { id = 1 })" class="zone-link">
                    <polygon points="602,410 923,410 923,582 688,748 573,630 573,510 602,510" class="zone-polygon zone-1" />
                </a>
            </svg>
        </div>
    </div>
</div>

<style>
    /* Premium Hover & Interactive SVG Styling */
    .zone-link {
        cursor: pointer;
        outline: none;
    }

    .zone-polygon {
        fill: rgba(255, 255, 255, 0);
        stroke: transparent;
        stroke-width: 2.5;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Zone Specific Colors corresponding to the map borders */
    /* Zone 1: Yellow */
    .zone-1:hover {
        fill: rgba(234, 179, 8, 0.15);
        stroke: rgb(234, 179, 8);
        filter: drop-shadow(0 0 8px rgba(234, 179, 8, 0.5));
    }

    /* Zone 2: Deep Pink / Magenta */
    .zone-2:hover {
        fill: rgba(236, 72, 153, 0.35);
        stroke: rgb(236, 72, 153);
        stroke-width: 3.5;
        filter: drop-shadow(0 0 12px rgba(236, 72, 153, 0.65));
    }

    /* Zone 3: Orange */
    .zone-3:hover {
        fill: rgba(249, 115, 22, 0.15);
        stroke: rgb(249, 115, 22);
        filter: drop-shadow(0 0 8px rgba(249, 115, 22, 0.5));
    }

    /* Zone 4: Purple */
    .zone-4:hover {
        fill: rgba(168, 85, 247, 0.15);
        stroke: rgb(168, 85, 247);
        filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.5));
    }

    /* Zone 5: Cyan/Blue */
    .zone-5:hover {
        fill: rgba(6, 182, 212, 0.15);
        stroke: rgb(6, 182, 212);
        filter: drop-shadow(0 0 8px rgba(6, 182, 212, 0.5));
    }

    /* Zone 6: Green */
    .zone-6:hover {
        fill: rgba(34, 197, 94, 0.15);
        stroke: rgb(34, 197, 94);
        filter: drop-shadow(0 0 8px rgba(34, 197, 94, 0.5));
    }
</style>
