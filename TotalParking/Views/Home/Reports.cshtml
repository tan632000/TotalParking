@{
    Layout = "~/Views/Shared/_ScadaLayout.cshtml";
}

<div class="p-6 pb-12 min-h-[calc(100vh-3.5rem)] text-slate-100" style="background: rgb(15, 23, 42); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="space-y-6">
        <!-- Title and Action Buttons -->
        <div class="flex flex-col md:flex-row justify-between md:items-center gap-4 pb-4 border-b border-slate-800">
            <div>
                <h1 class="text-2xl font-bold tracking-tight">Báo cáo & Thống kê hệ thống</h1>
                <p class="text-slate-400 text-sm mt-1">Truy xuất báo cáo hoạt động, mật độ, phân tích Pareto lỗi thiết bị và doanh thu bãi đỗ xe.</p>
            </div>
            <div class="flex gap-2 self-start md:self-auto">
                <button onclick="alert('Đã xuất báo cáo thành công sang file Excel!')" class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs bg-green-900/50 hover:bg-green-800/50 text-green-300 border border-green-700/50 transition-colors font-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-spreadsheet"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M8 13h2"></path><path d="M14 13h2"></path><path d="M8 17h2"></path><path d="M14 17h2"></path></svg>
                    Xuất Excel
                </button>
                <button onclick="alert('Đã xuất báo cáo thành công sang file PDF!')" class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs bg-blue-900/50 hover:bg-blue-800/50 text-blue-300 border border-blue-700/50 transition-colors font-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
                    Xuất PDF
                </button>
            </div>
        </div>

        <!-- Main Layout Split -->
        <div class="grid grid-cols-1 xl:grid-cols-4 gap-6">
            <!-- Sidebar: Report Options -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-4 space-y-1.5 h-fit shadow-lg">
                <div class="text-slate-500 text-[10px] font-mono uppercase mb-3 px-3 tracking-wider">Danh mục Báo cáo</div>
                
                <button id="btn-density" onclick="switchReportTab('density')" class="report-tab-btn active">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity text-blue-400"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
                    Mật độ & Lưu lượng
                </button>
                
                <button id="btn-alarms" onclick="switchReportTab('alarms')" class="report-tab-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-triangle text-amber-500"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>
                    Phân tích lỗi & Pareto
                </button>
                
                <button id="btn-maintenance" onclick="switchReportTab('maintenance')" class="report-tab-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wrench text-purple-400"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
                    Lịch sử bảo trì
                </button>
                
                <button id="btn-cards" onclick="switchReportTab('cards')" class="report-tab-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card text-emerald-400"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
                    Lịch sử thẻ xe
                </button>
                <button id="btn-revenue" onclick="switchReportTab('revenue')" class="report-tab-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-banknote text-yellow-500"><rect width="20" height="12" x="2" y="6" rx="2"></rect><circle cx="12" cy="12" r="2"></circle><line x1="6" x2="6" y1="12" y2="12"></line><line x1="18" x2="18" y1="12" y2="12"></line></svg>
                    Báo cáo doanh thu từ xa
                </button>
                <button id="btn-pallet-frequency" onclick="switchReportTab('pallet-frequency')" class="report-tab-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    Tần suất hoạt động Pallet
                </button>
            </div>

            <!-- Content Area -->
            <div class="xl:col-span-3 space-y-4">
                <!-- Filter Bar -->
                <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-4 flex flex-wrap gap-4 items-center shadow-lg">
                    <div class="flex items-center gap-2">
                        <span class="text-slate-500 text-xs font-mono">Từ ngày</span>
                        <input type="date" class="bg-slate-800 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-300 font-mono outline-none focus:border-blue-500" value="2026-06-01">
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-slate-500 text-xs font-mono">Đến ngày</span>
                        <input type="date" class="bg-slate-800 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-300 font-mono outline-none focus:border-blue-500" value="2026-06-16">
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-slate-500 text-xs font-mono">Phân khu</span>
                        <select class="bg-slate-800 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-300 font-mono outline-none focus:border-blue-500">
                            <option value="all">Tất cả các Zone</option>
                            <option value="A">Zone A (Hầm B1)</option>
                            <option value="B">Zone B (Hầm B2)</option>
                            <option value="C">Zone C (Hầm B3)</option>
                            <option value="D">Zone D (Tầng 1)</option>
                        </select>
                    </div>
                    <button onclick="alert('Đã cập nhật dữ liệu báo cáo mới!')" class="px-4 py-1.5 rounded text-xs bg-blue-600 hover:bg-blue-500 text-white font-bold transition-colors shadow">Tạo báo cáo</button>
                </div>

                <!-- Tab Panels -->

                <!-- 1. Density Panel -->
                <div id="panel-density" class="report-panel active space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-lg">
                            <h3 class="text-white text-sm font-bold mb-3">Mật độ đỗ xe theo ngày trong tuần (%)</h3>
                            <div class="space-y-3 pt-2">
                                <div>
                                    <div class="flex justify-between text-xs mb-1 font-mono">
                                        <span class="text-slate-300">Thứ Hai (T2)</span>
                                        <span class="text-blue-400 font-bold">64%</span>
                                    </div>
                                    <div class="h-2 bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-blue-500 rounded-full" style="width: 64%"></div></div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-xs mb-1 font-mono">
                                        <span class="text-slate-300">Thứ Ba (T3)</span>
                                        <span class="text-blue-400 font-bold">78%</span>
                                    </div>
                                    <div class="h-2 bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-blue-500 rounded-full" style="width: 78%"></div></div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-xs mb-1 font-mono">
                                        <span class="text-slate-300">Thứ Tư (T4)</span>
                                        <span class="text-blue-400 font-bold">70%</span>
                                    </div>
                                    <div class="h-2 bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-blue-500 rounded-full" style="width: 70%"></div></div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-xs mb-1 font-mono">
                                        <span class="text-slate-300">Thứ Năm (T5)</span>
                                        <span class="text-blue-400 font-bold">85%</span>
                                    </div>
                                    <div class="h-2 bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-blue-500 rounded-full" style="width: 85%"></div></div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-xs mb-1 font-mono">
                                        <span class="text-slate-300">Thứ Sáu (T6)</span>
                                        <span class="text-blue-400 font-bold">92%</span>
                                    </div>
                                    <div class="h-2 bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-blue-500 rounded-full" style="width: 92%"></div></div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-xs mb-1 font-mono">
                                        <span class="text-slate-300">Thứ Bảy (T7)</span>
                                        <span class="text-amber-500 font-bold">55%</span>
                                    </div>
                                    <div class="h-2 bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-amber-500 rounded-full" style="width: 55%"></div></div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-xs mb-1 font-mono">
                                        <span class="text-slate-300">Chủ Nhật (CN)</span>
                                        <span class="text-emerald-400 font-bold">40%</span>
                                    </div>
                                    <div class="h-2 bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-emerald-500 rounded-full" style="width: 40%"></div></div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-lg">
                            <h3 class="text-white text-sm font-bold mb-3">Phân loại phương tiện đỗ thực tế</h3>
                            <div class="flex flex-col justify-center h-full space-y-4 pt-2">
                                <div class="flex items-center justify-between p-3 bg-slate-800/20 rounded-lg border border-slate-800">
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded bg-blue-500 inline-block"></span>
                                        <span class="text-xs font-semibold text-slate-300">Xe SUV (Gầm cao)</span>
                                    </div>
                                    <span class="font-mono text-xs font-bold text-blue-400">47% (37 xe)</span>
                                </div>
                                <div class="flex items-center justify-between p-3 bg-slate-800/20 rounded-lg border border-slate-800">
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded bg-emerald-500 inline-block"></span>
                                        <span class="text-xs font-semibold text-slate-300">Xe Sedan / Hatchback</span>
                                    </div>
                                    <span class="font-mono text-xs font-bold text-emerald-400">49% (54 xe)</span>
                                </div>
                                <div class="flex items-center justify-between p-3 bg-slate-800/20 rounded-lg border border-slate-800">
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded bg-rose-500 inline-block"></span>
                                        <span class="text-xs font-semibold text-slate-300">Xe quá khổ (Từ chối)</span>
                                    </div>
                                    <span class="font-mono text-xs font-bold text-rose-400">4% (3 xe)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Alarms Panel (Pareto Details) -->
                <div id="panel-alarms" class="report-panel space-y-4">
                    <!-- Pareto Chart Mockup using pure HTML/CSS elements -->
                    <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-lg">
                        <h3 class="text-white text-sm font-bold mb-4">Biểu đồ Pareto lỗi thiết bị (Nguyên nhân lỗi & Tỷ lệ tích lũy)</h3>
                        
                        <div class="space-y-4">
                            <!-- Visual Pareto Bars & Line -->
                            <div class="grid grid-cols-1 lg:grid-cols-6 gap-4 items-end min-h-[140px] pt-4 px-2 border-b border-slate-800">
                                <!-- Bar 1: Motor quá tải -->
                                <div class="text-center space-y-2">
                                    <span class="text-[10px] font-mono text-slate-400">12 lần (30.0%)</span>
                                    <div class="w-full bg-blue-600 rounded-t-md mx-auto" style="height: 120px; max-width: 60px;"></div>
                                    <div class="text-[10px] font-bold text-slate-300 truncate">Motor quá tải</div>
                                </div>
                                <!-- Bar 2: Lỗi Cảm biến hành trình -->
                                <div class="text-center space-y-2">
                                    <span class="text-[10px] font-mono text-slate-400">9 lần (22.5%)</span>
                                    <div class="w-full bg-blue-600/80 rounded-t-md mx-auto" style="height: 90px; max-width: 60px;"></div>
                                    <div class="text-[10px] font-bold text-slate-300 truncate">Cảm biến HT</div>
                                </div>
                                <!-- Bar 3: Mất kết nối PLC -->
                                <div class="text-center space-y-2">
                                    <span class="text-[10px] font-mono text-slate-400">7 lần (17.5%)</span>
                                    <div class="w-full bg-blue-600/70 rounded-t-md mx-auto" style="height: 70px; max-width: 60px;"></div>
                                    <div class="text-[10px] font-bold text-slate-300 truncate">Mất kết nối</div>
                                </div>
                                <!-- Bar 4: Nút E-stop kích hoạt -->
                                <div class="text-center space-y-2">
                                    <span class="text-[10px] font-mono text-slate-400">5 lần (12.5%)</span>
                                    <div class="w-full bg-blue-600/50 rounded-t-md mx-auto" style="height: 50px; max-width: 60px;"></div>
                                    <div class="text-[10px] font-bold text-slate-300 truncate">Nút E-Stop</div>
                                </div>
                                <!-- Bar 5: Lỗi nguồn điện -->
                                <div class="text-center space-y-2">
                                    <span class="text-[10px] font-mono text-slate-400">4 lần (10.0%)</span>
                                    <div class="w-full bg-blue-600/40 rounded-t-md mx-auto" style="height: 40px; max-width: 60px;"></div>
                                    <div class="text-[10px] font-bold text-slate-300 truncate">Nguồn điện</div>
                                </div>
                                <!-- Bar 6: Các lỗi khác -->
                                <div class="text-center space-y-2">
                                    <span class="text-[10px] font-mono text-slate-400">3 lần (7.5%)</span>
                                    <div class="w-full bg-blue-600/30 rounded-t-md mx-auto" style="height: 30px; max-width: 60px;"></div>
                                    <div class="text-[10px] font-bold text-slate-300 truncate">Khác</div>
                                </div>
                            </div>
                        </div>

                        <!-- Pareto Table -->
                        <div class="overflow-x-auto mt-6">
                            <table class="w-full text-xs font-mono">
                                <thead class="border-b border-slate-700/60 bg-slate-800/30">
                                    <tr>
                                        <th class="text-left text-slate-400 px-3 py-2.5 font-bold">Nguyên nhân lỗi</th>
                                        <th class="text-left text-slate-400 px-3 py-2.5 font-bold">Số lần xuất hiện</th>
                                        <th class="text-left text-slate-400 px-3 py-2.5 font-bold">Tỉ lệ (%)</th>
                                        <th class="text-left text-slate-400 px-3 py-2.5 font-bold text-amber-500">Tích lũy lũy kế (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-b border-slate-800/60 hover:bg-slate-800/10">
                                        <td class="px-3 py-2 text-slate-200">Lỗi quá tải dòng Motor (Motor overload)</td>
                                        <td class="px-3 py-2 text-slate-300 font-bold">12</td>
                                        <td class="px-3 py-2 text-slate-400">30.0%</td>
                                        <td class="px-3 py-2 text-amber-400 font-bold">30.0%</td>
                                    </tr>
                                    <tr class="border-b border-slate-800/60 hover:bg-slate-800/10">
                                        <td class="px-3 py-2 text-slate-200">Sai lệch cảm biến hành trình khay đỗ</td>
                                        <td class="px-3 py-2 text-slate-300 font-bold">9</td>
                                        <td class="px-3 py-2 text-slate-400">22.5%</td>
                                        <td class="px-3 py-2 text-amber-400 font-bold">52.5%</td>
                                    </tr>
                                    <tr class="border-b border-slate-800/60 hover:bg-slate-800/10">
                                        <td class="px-3 py-2 text-slate-200">Mất tín hiệu kết nối Modbus TCP PLC</td>
                                        <td class="px-3 py-2 text-slate-300 font-bold">7</td>
                                        <td class="px-3 py-2 text-slate-400">17.5%</td>
                                        <td class="px-3 py-2 text-amber-400 font-bold">70.0%</td>
                                    </tr>
                                    <tr class="border-b border-slate-800/60 hover:bg-slate-800/10">
                                        <td class="px-3 py-2 text-slate-200">Kích hoạt nút khẩn cấp E-Stop tại trạm</td>
                                        <td class="px-3 py-2 text-slate-300 font-bold">5</td>
                                        <td class="px-3 py-2 text-slate-400">12.5%</td>
                                        <td class="px-3 py-2 text-amber-400 font-bold">82.5% <span class="text-[9px] text-emerald-400 font-semibold px-1 rounded bg-emerald-950/40">(Ngưỡng Pareto 80%)</span></td>
                                    </tr>
                                    <tr class="border-b border-slate-800/60 hover:bg-slate-800/10">
                                        <td class="px-3 py-2 text-slate-200">Sụt áp hoặc lỗi nguồn điện lưới đầu vào</td>
                                        <td class="px-3 py-2 text-slate-300 font-bold">4</td>
                                        <td class="px-3 py-2 text-slate-400">10.0%</td>
                                        <td class="px-3 py-2 text-amber-400">92.5%</td>
                                    </tr>
                                    <tr class="border-b border-slate-800/60 hover:bg-slate-800/10">
                                        <td class="px-3 py-2 text-slate-200">Các lỗi truyền thông phụ khác</td>
                                        <td class="px-3 py-2 text-slate-300 font-bold">3</td>
                                        <td class="px-3 py-2 text-slate-400">7.5%</td>
                                        <td class="px-3 py-2 text-slate-400">100.0%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 3. Maintenance Panel -->
                <div id="panel-maintenance" class="report-panel space-y-4">
                    <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-lg">
                        <h3 class="text-white text-sm font-bold mb-3">Lịch sử bảo trì thiết bị</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-xs font-mono">
                                <thead class="border-b border-slate-700/60 bg-slate-800/30">
                                    <tr>
                                        <th class="text-left text-slate-400 px-3 py-2 font-bold">Thiết bị</th>
                                        <th class="text-left text-slate-400 px-3 py-2 font-bold">Loại bảo trì</th>
                                        <th class="text-left text-slate-400 px-3 py-2 font-bold">Ngày thực hiện</th>
                                        <th class="text-left text-slate-400 px-3 py-2 font-bold">Kỹ thuật viên</th>
                                        <th class="text-left text-slate-400 px-3 py-2 font-bold">Đánh giá</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-b border-slate-850">
                                        <td class="px-3 py-2 text-slate-200">Motor Nâng hạ Block A-04</td>
                                        <td class="px-3 py-2 text-slate-400">Thay thế cuộn dây stator</td>
                                        <td class="px-3 py-2 text-slate-400">2026-06-10</td>
                                        <td class="px-3 py-2 text-slate-300">Nguyễn Văn Hùng</td>
                                        <td class="px-3 py-2 text-emerald-400 font-semibold">Tốt · Chạy êm</td>
