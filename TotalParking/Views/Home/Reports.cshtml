        `;
    }

    function clearCarFinder() {
        document.getElementById('search-query-input').value = '';
        const container = document.getElementById('finder-result-container');
        container.innerHTML = `
            <div class="text-slate-550 space-y-2 py-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-slate-700"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                <div class="text-xs font-mono">Nhập thông tin biển số hoặc số thẻ từ để dò vị trí pallet đỗ xe cơ khí thực tế.</div>
            </div>
        `;
    }

    function simulateReleaseCar(slot, block) {
        const btn = document.getElementById('btn-release-car');
        const progressBox = document.getElementById('release-progress-box');
        const progressBar = document.getElementById('release-progress-bar');
        const percentText = document.getElementById('release-percent-text');
        const statusText = document.getElementById('release-status-text');
        const timerText = document.getElementById('release-timer-text');
        
        btn.disabled = true;
        btn.className = "w-full sm:w-auto px-4 py-2 bg-slate-800 text-slate-500 text-xs font-bold rounded-lg cursor-not-allowed flex items-center justify-center gap-1.5 border border-slate-750";
        progressBox.classList.remove('hidden');

        let percent = 0;
        const interval = setInterval(() => {
            percent += 10;
            progressBar.style.width = percent + "%";
            percentText.innerText = percent + "%";

            if (percent === 30) {
                statusText.innerText = "PLC phản hồi: Mâm xoay đang hạ...";
                timerText.innerText = "Dự kiến: 2s";
            } else if (percent === 70) {
                statusText.innerText = "Cảm biến an toàn: Đường ra thông thoáng...";
                timerText.innerText = "Dự kiến: 1s";
            } else if (percent === 100) {
                clearInterval(interval);
                statusText.innerText = "Lấy xe thành công! Mâm đỗ đã hạ về mặt đất.";
                statusText.className = "text-emerald-400 font-bold";
                progressBar.className = "h-full bg-emerald-500 transition-all duration-300";
                timerText.innerText = "Hoàn thành";
                
                // Add log entry to history table dynamically
                const now = new Date();
                const dateStr = now.getDate().toString().padStart(2, '0') + '-' + (now.getMonth() + 1).toString().padStart(2, '0') + '-' + now.getFullYear();
                const timeStr = dateStr + " " + now.toLocaleTimeString('vi-VN', { hour12: false });
                const table = document.getElementById('history-data-table').getElementsByTagName('tbody')[0];
                const newRow = table.insertRow(0);
                newRow.className = "border-b border-slate-850 hover:bg-slate-800/20";
                
                // Set data attributes on the newly inserted row for the advanced filters
                newRow.setAttribute('data-time', timeStr);
                newRow.setAttribute('data-card', 'RFID-Release');
                newRow.setAttribute('data-plate', 'RELEASED');
                newRow.setAttribute('data-action', 'out');
                newRow.setAttribute('data-status', 'retrieved');
                newRow.setAttribute('data-zone', block.includes('A-') ? 'A' : (block.includes('B-') ? 'B' : 'C'));
                newRow.setAttribute('data-block', block.trim());

                newRow.innerHTML = `
                    <td class="px-3 py-2 text-slate-400">${timeStr}</td>
                    <td class="px-3 py-2 text-slate-300">RFID-Release</td>
                    <td class="px-3 py-2 text-emerald-400 font-bold">RELEASED</td>
                    <td class="px-3 py-2 text-slate-400">Sedan/SUV</td>
                    <td class="px-3 py-2 text-blue-400 font-bold">${block} (${slot})</td>
                    <td class="px-3 py-2"><span class="text-amber-400 font-semibold bg-amber-950/20 border border-amber-800/30 px-1.5 py-0.5 rounded text-[10px]">Lấy xe ra</span></td>
                    <td class="px-3 py-2 text-slate-300">0 đ (Remote)</td>
                `;

                // Recalculate count
                filterHistoryTable();

                setTimeout(() => {
                    progressBox.classList.add('hidden');
                    btn.disabled = false;
                    btn.className = "w-full sm:w-auto px-4 py-2 bg-amber-600 hover:bg-amber-500 text-slate-950 text-xs font-bold rounded-lg transition-all flex items-center justify-center gap-1.5 shadow-lg shadow-amber-500/10";
                    statusText.className = "text-amber-400 font-bold";
                    statusText.innerText = "Đang gửi lệnh PLC xoay mâm...";
                    progressBar.className = "h-full bg-amber-500 transition-all duration-300";
                    progressBar.style.width = "0%";
                    percentText.innerText = "0%";
                }, 4000);
            }
        }, 300);
    }

    function filterHistoryTable() {
        const dateFrom = document.getElementById('history-date-from').value;
        const dateTo = document.getElementById('history-date-to').value;
        const searchText = document.getElementById('history-search-text').value.toUpperCase().trim();
        const action = document.getElementById('history-filter-action').value;
        const status = document.getElementById('history-filter-status').value;
        const zone = document.getElementById('history-filter-zone').value;

        const table = document.getElementById('history-data-table');
        const trs = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
        let count = 0;

        for (let i = 0; i < trs.length; i++) {
            const tr = trs[i];
            
            // Get data attributes or fallback to parsing row
            const rowTime = tr.getAttribute('data-time') || tr.cells[0].textContent.trim();
            const rowCard = (tr.getAttribute('data-card') || tr.cells[1].textContent.trim()).toUpperCase();
            const rowPlate = (tr.getAttribute('data-plate') || tr.cells[2].textContent.trim()).toUpperCase();
            const rowAction = tr.getAttribute('data-action') || (tr.cells[5].textContent.includes('Gửi') ? 'in' : 'out');
            const rowStatus = tr.getAttribute('data-status') || (tr.cells[5].textContent.includes('Gửi') ? 'parked' : 'retrieved');
            const locationText = tr.cells[4].textContent.toUpperCase();
            
            // Extract Zone
            let rowZone = tr.getAttribute('data-zone') || '';
            if (!rowZone) {
                if (locationText.includes('ZONE 1') || locationText.includes('(A)')) rowZone = 'A';
                else if (locationText.includes('ZONE 2') || locationText.includes('(B)')) rowZone = 'B';
                else if (locationText.includes('ZONE 3') || locationText.includes('(C)')) rowZone = 'C';
                else if (locationText.includes('ZONE 4') || locationText.includes('(D)')) rowZone = 'D';
            }

            // Extract Date (from DD-MM-YYYY HH:mm:ss to YYYY-MM-DD)
            let rowDate = '';
            try {
                const datePart = rowTime.split(' ')[0];
                const parts = datePart.split('-');
                rowDate = `${parts[2]}-${parts[1]}-${parts[0]}`;
            } catch (e) {
                rowDate = '';
            }

            let match = true;

            // 1. Date From filter
            if (dateFrom && rowDate && rowDate < dateFrom) match = false;
            
            // 2. Date To filter
            if (dateTo && rowDate && rowDate > dateTo) match = false;

            // 3. Search text (Card or Plate)
            if (searchText) {
                if (rowCard.indexOf(searchText) === -1 && rowPlate.indexOf(searchText) === -1) {
                    match = false;
                }
            }

            // 4. Action type
            if (action !== 'all' && rowAction !== action) match = false;

            // 5. Status
            if (status !== 'all' && rowStatus !== status) match = false;

            // 6. Zone
            if (zone !== 'all' && rowZone !== zone) match = false;

            if (match) {
                tr.style.display = "";
                count++;
            } else {
                tr.style.display = "none";
            }
        }

        document.getElementById('history-results-count').innerText = `Tìm thấy ${count} lượt gửi xe khớp với điều kiện`;
    }

    function resetHistoryFilters() {
        document.getElementById('history-date-from').value = '2026-06-01';
        document.getElementById('history-date-to').value = '2026-06-16';
        document.getElementById('history-search-text').value = '';
        document.getElementById('history-filter-action').value = 'all';
        document.getElementById('history-filter-status').value = 'all';
        document.getElementById('history-filter-zone').value = 'all';
        filterHistoryTable();
    }

    // =========================================================================
    // PALLET FREQUENCY HEATMAP & MAINTENANCE LOGIC
    // =========================================================================

    // Default mock data mapping block ID to array of 12 numbers representing cycles
    const defaultPalletCycles = {
        // Zone 1
        "Block A-01": [12, 115, 34, 75, 45, 88, 120, 20, 15, 60, 95, 30],
        "Block A-02": [25, 48, 102, 12, 55, 67, 10, 92, 110, 40, 15, 8],
        "Block A-03": [85, 30, 42, 130, 90, 22, 60, 47, 12, 105, 50, 70],
        // Zone 2
        "Block A-04": [115, 102, 80, 40, 95, 125, 20, 15, 60, 30, 45, 90],
        "Block B-01": [34, 52, 110, 75, 88, 15, 42, 130, 60, 25, 95, 10],
        "Block B-02": [45, 85, 20, 65, 12, 105, 78, 30, 90, 115, 50, 40],
        // Zone 3
        "Block B-03": [90, 110, 35, 60, 80, 25, 125, 45, 15, 55, 95, 30],
        "Block B-04": [12, 48, 135, 92, 55, 70, 8, 102, 65, 30, 115, 18],
        "Block C-01": [85, 25, 60, 105, 40, 115, 75, 22, 50, 90, 10, 125],
        // Zone 4
        "Block C-02": [130, 45, 20, 95, 70, 15, 110, 88, 35, 60, 102, 25],
        "Block C-03": [40, 80, 115, 10, 55, 90, 30, 125, 65, 105, 22, 50],
        "Block C-04": [15, 102, 75, 120, 45, 60, 88, 25, 135, 30, 95, 8],
        // Zone 5
        "Block D-01": [95, 115, 20, 55, 10, 85, 125, 40, 60, 30, 102, 70],
        "Block D-02": [50, 30, 110, 75, 120, 45, 15, 90, 88, 135, 65, 22],
        "Block D-03": [105, 12, 80, 95, 25, 115, 60, 130, 42, 50, 78, 35],
        // Zone 6
        "Block E-01": [35, 90, 115, 20, 125, 55, 70, 10, 102, 65, 80, 45],
        "Block E-02": [88, 110, 40, 135, 15, 95, 30, 120, 50, 75, 22, 60],
        "Block E-03": [12, 65, 102, 80, 45, 115, 25, 90, 130, 35, 55, 105]
    };

    const zoneBlocksMap = {
        "1": ["Block A-01", "Block A-02", "Block A-03"],
        "2": ["Block A-04", "Block B-01", "Block B-02"],
        "3": ["Block B-03", "Block B-04", "Block C-01"],
        "4": ["Block C-02", "Block C-03", "Block C-04"],
        "5": ["Block D-01", "Block D-02", "Block D-03"],
        "6": ["Block E-01", "Block E-02", "Block E-03"]
    };

    let palletCycleData = {};
    let selectedBlockId = null;
    let selectedSlotIdx = null;

    // Load data from localStorage or initialize defaults
    function initPalletFrequencyData() {
        const stored = localStorage.getItem('palletCycleData');
        if (stored) {
            try {
                palletCycleData = JSON.parse(stored);
            } catch (e) {
                console.error("Lỗi parse dữ liệu từ localStorage:", e);
                palletCycleData = JSON.parse(JSON.stringify(defaultPalletCycles));
            }
        } else {
            palletCycleData = JSON.parse(JSON.stringify(defaultPalletCycles));
            localStorage.setItem('palletCycleData', JSON.stringify(palletCycleData));
        }
    }

    // Populate blocks selection dropdown based on chosen zone
    function updateFreqBlockOptions() {
        const zoneId = document.getElementById('freq-zone').value;
        const blocksList = zoneBlocksMap[zoneId] || [];
        const blockSelect = document.getElementById('freq-block');
        
        blockSelect.innerHTML = '';
        blocksList.forEach(block => {
            const opt = document.createElement('option');
            opt.value = block;
            opt.textContent = block;
            blockSelect.appendChild(opt);
        });

        loadFreqBlock();
    }

    // Handle block change
    function loadFreqBlock() {
        const blockId = document.getElementById('freq-block').value;
        if (!blockId) return;

        // Reset details panel selection state
        selectedBlockId = blockId;
        selectedSlotIdx = null;
        
        // Render Heatmap
        renderPalletHeatmap(blockId);

        // Reset detail panel UI
        document.getElementById('freq-panel-title').textContent = "Chi tiết khay đỗ";
        document.getElementById('freq-panel-subtitle').textContent = "Vui lòng chọn một pallet trên sơ đồ";
        document.getElementById('freq-panel-detail-content').innerHTML = `
            <div class="text-slate-500 text-xs font-mono py-8 text-center">
                Click chọn một khay đỗ Pallet trên sơ đồ nhiệt để xem thống kê chu kỳ hao mòn và thực hiện xử lý.
            </div>
        `;
        document.getElementById('freq-panel-actions').classList.add('hidden');
    }

    // Render 12-pallet grid heatmap
    function renderPalletHeatmap(blockId) {
        const gridContainer = document.getElementById('pallet-heatmap-grid');
        gridContainer.innerHTML = '';

        const cyclesArray = palletCycleData[blockId] || Array(12).fill(0);

        // Render levels 3 down to 1
        for (let lvl = 3; lvl >= 1; lvl--) {
            for (let col = 1; col <= 4; col++) {
                const slotNum = (lvl - 1) * 4 + col;
                const slotIdx = slotNum - 1;
                const slotId = 'P' + String(slotNum).padStart(2, '0');
                const cycles = cyclesArray[slotIdx] || 0;

                // Color coding rules:
                // Red (>100): pallet-glow-red, Yellow (50-99), Green (<50)
                let cellClass = "";
                let statusBadge = "";
                
                if (cycles >= 100) {
                    cellClass = "pallet-glow-red border border-red-500/80 text-red-300";
                    statusBadge = `<span class="px-1 py-0.5 rounded text-[8px] font-bold bg-red-500/20 text-red-400 border border-red-500/30">CẦN BẢO TRÌ</span>`;
                } else if (cycles >= 50) {
                    cellClass = "bg-amber-950/20 border border-amber-500/40 text-amber-300";
                    statusBadge = `<span class="px-1 py-0.5 rounded text-[8px] font-bold bg-amber-500/20 text-amber-400 border border-amber-500/30">CẢNH BÁO</span>`;
                } else {
                    cellClass = "bg-green-950/15 border border-green-500/30 text-green-300";
                    statusBadge = `<span class="px-1 py-0.5 rounded text-[8px] font-bold bg-green-500/20 text-green-400 border border-green-500/30">TỐT</span>`;
                }

                // Check selection outline
                const isSelected = (selectedSlotIdx === slotIdx);
                const selectStyle = isSelected ? "ring-2 ring-blue-500 border-transparent shadow-[0_0_15px_rgba(59,130,246,0.5)] scale-[1.02] z-10" : "";

                const cellHtml = `
                    <div onclick="clickFreqPallet('${blockId}', ${slotIdx})" 
                         class="rounded-lg p-2.5 transition-all duration-200 cursor-pointer flex flex-col justify-between h-20 font-mono select-none ${cellClass} ${selectStyle}">
                        <div class="flex justify-between items-start">
                            <span class="text-[9px] font-bold text-slate-400">T${lvl}-C${col}</span>
                            ${statusBadge}
                        </div>
                        <div class="mt-1.5 flex justify-between items-end">
                            <span class="text-xs font-bold font-mono tracking-wider">${slotId}</span>
                            <span class="text-[10px] text-right font-semibold">${cycles} c.y</span>
                        </div>
                    </div>
                `;
                
                const wrapper = document.createElement('div');
                wrapper.innerHTML = cellHtml;
                gridContainer.appendChild(wrapper.firstElementChild);
            }
        }
    }

    // Handle click on pallet
    function clickFreqPallet(blockId, slotIdx) {
        selectedBlockId = blockId;
        selectedSlotIdx = slotIdx;
        
        // Re-render heatmap to show selection borders
        renderPalletHeatmap(blockId);

        const cyclesArray = palletCycleData[blockId] || Array(12).fill(0);
        const cycles = cyclesArray[slotIdx] || 0;
        
        const lvl = Math.floor(slotIdx / 4) + 1;
        const col = (slotIdx % 4) + 1;
        const palletName = `Pallet P${String(slotIdx + 1).padStart(2, '0')}`;
        
        // Calculate wear percentage (cycles / 100 * 100)
        const wearRate = Math.round((cycles / 100) * 100);

        // Update detail panel elements
        document.getElementById('freq-panel-title').textContent = `${palletName}`;
        document.getElementById('freq-panel-subtitle').textContent = `${blockId} · Vị trí: Tầng ${lvl} - Cột ${col}`;

        let statusClass = "";
        let statusText = "";
        let descText = "";

        if (cycles >= 100) {
            statusClass = "bg-red-500/10 border-red-500/30 text-red-400";
            statusText = "CẦN BẢO TRÌ NGAY";
            descText = `Pallet đã vượt quá giới hạn an toàn (${cycles}/100 chu kỳ). Có nguy cơ cao mài mòn bạc đạn và giãn xích kéo pallet. Yêu cầu cử kỹ thuật viên kiểm tra thực địa lập tức.`;
        } else if (cycles >= 50) {
            statusClass = "bg-amber-500/10 border-amber-500/30 text-amber-400";
            statusText = "CẢNH BÁO BẢO TRÌ";
            descText = `Tần suất hoạt động đạt mức trung bình cao (${cycles}/100 chu kỳ). Cần theo dõi sát hoặc có thể cân nhắc bảo trì sớm để phân bổ đều tải trọng cho hệ thống.`;
        } else {
            statusClass = "bg-emerald-500/10 border-emerald-500/30 text-emerald-400";
            statusText = "HOẠT ĐỘNG TỐT";
            descText = `Khay đỗ hoạt động dưới ngưỡng cảnh báo (${cycles}/100 chu kỳ). Thiết bị cơ khí đang ở trạng thái tối ưu, không cần bảo dưỡng đột xuất.`;
        }

        const detailsHtml = `
            <div class="space-y-4 font-mono text-xs mt-2">
                <!-- Status Row -->
                <div class="flex justify-between items-center p-2 rounded-lg border ${statusClass}">
                    <span class="font-bold">Trạng thái:</span>
                    <span class="font-bold">${statusText}</span>
                </div>

                <!-- Specs -->
                <div class="grid grid-cols-2 gap-2 text-[11px]">
                    <div class="bg-slate-950/60 p-2.5 rounded border border-slate-850">
                        <span class="text-slate-500 text-[9px] uppercase tracking-wider block">Chu kỳ đã chạy</span>
                        <span class="text-slate-200 font-bold block mt-0.5">${cycles} / 100 chu kỳ</span>
                    </div>
                    <div class="bg-slate-950/60 p-2.5 rounded border border-slate-850">
                        <span class="text-slate-500 text-[9px] uppercase tracking-wider block">Mức hao mòn cơ khí</span>
                        <span class="font-bold block mt-0.5 ${cycles >= 100 ? 'text-red-400' : (cycles >= 50 ? 'text-amber-400' : 'text-emerald-400')}">${wearRate}%</span>
                    </div>
                </div>

                <!-- Wear level progress bar -->
                <div class="space-y-1">
                    <div class="flex justify-between text-[10px] text-slate-400">
                        <span>Hao mòn hệ thống</span>
                        <span>${wearRate}%</span>
                    </div>
                    <div class="h-2 bg-slate-950 rounded-full overflow-hidden border border-slate-800">
                        <div class="h-full rounded-full transition-all duration-300 ${cycles >= 100 ? 'bg-red-500' : (cycles >= 50 ? 'bg-amber-500' : 'bg-green-500')}" style="width: ${Math.min(wearRate, 100)}%;"></div>
                    </div>
                </div>

                <!-- Diagnosis Note -->
                <div class="bg-slate-950/60 p-3 rounded-lg border border-slate-850 space-y-1 text-slate-400 text-[11px] leading-relaxed">
                    <span class="text-slate-200 font-bold block uppercase text-[10px]">Đánh giá thiết bị:</span>
                    ${descText}
                </div>
            </div>
        `;

        document.getElementById('freq-panel-detail-content').innerHTML = detailsHtml;

        // Show action buttons
        document.getElementById('freq-panel-actions').classList.remove('hidden');
    }

    // Reset cycles of selected pallet to 0
    function execResetPalletCycle() {
        if (!selectedBlockId || selectedSlotIdx === null) {
            alert("Vui lòng chọn một pallet trên sơ đồ trước!");
            return;
        }

        const palletName = `Pallet P${String(selectedSlotIdx + 1).padStart(2, '0')}`;
        
        // Confirm action
        if (confirm(`Bạn có chắc chắn muốn xác nhận đã hoàn tất bảo trì và Reset chu kỳ chạy của ${palletName} (${selectedBlockId}) về 0?`)) {
            // Update data
            palletCycleData[selectedBlockId][selectedSlotIdx] = 0;
            
            // Save to localStorage
            localStorage.setItem('palletCycleData', JSON.stringify(palletCycleData));
            
            // Alert success
            alert(`Bảo trì thành công! Đã reset chu kỳ chạy của ${palletName} về 0. Trạng thái Pallet đã cập nhật về HOẠT ĐỘNG TỐT.`);
            
            // Re-render
            renderPalletHeatmap(selectedBlockId);
            
            // Refresh details panel
            clickFreqPallet(selectedBlockId, selectedSlotIdx);
        }
    }

    // Mock create Work Order
    function createPalletWorkOrder() {
        if (!selectedBlockId || selectedSlotIdx === null) {
            alert("Vui lòng chọn một pallet trên sơ đồ trước!");
            return;
        }

        const palletName = `Pallet P${String(selectedSlotIdx + 1).padStart(2, '0')}`;
        const woId = "WO-" + Math.floor(100000 + Math.random() * 900000);
        
        alert(`Đã lập lịch Work Order bảo trì thành công!\nMã số: ${woId}\nThiết bị: ${palletName} - ${selectedBlockId}\nNội dung công việc: Kiểm tra bảo dưỡng cơ khí & xích tải.\nYêu cầu đã gửi tới kỹ thuật ca trực.`);
    }

    // Initialize on page load
    document.addEventListener("DOMContentLoaded", () => {
        initPalletFrequencyData();
        updateFreqBlockOptions();
    });
</script>