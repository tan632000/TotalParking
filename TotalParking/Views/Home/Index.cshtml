            <button class="rounded-lg p-3 text-left transition-all hover:scale-[1.02] hover:shadow-lg" style="background: rgb(15, 23, 42); border: 1px solid rgba(107, 114, 128, 0.267); cursor: pointer;">
                <div class="flex items-center justify-between mb-1">
                    <span style="color: rgb(248, 250, 252); font-size: 11px; font-weight: 600;">
                        Block C01
                    </span>
                    <span class="w-2 h-2 rounded-full" style="background: rgb(107, 114, 128);">
                    </span>
                </div>
                <div style="color: rgb(148, 163, 184); font-size: 10px;">
                    Z3
                </div>
                <div class="flex items-center justify-between mt-2">
                    <span style="color: rgb(107, 114, 128); font-size: 13px; font-weight: 700;">
                        0%
                    </span>
                    <span style="color: rgb(100, 116, 139); font-size: 10px;">
                        0/16
                    </span>
                </div>
                <div class="h-1 rounded-full mt-1" style="background: rgb(51, 65, 85);">
                    <div class="h-1 rounded-full" style="width: 0%; background: rgb(107, 114, 128);">
                    </div>
                </div>
                <div class="mt-1.5">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold" style="background: rgb(107, 114, 128); color: white; font-size: 11px;">
                        Offline
                    </span>
                </div>
            </button>
            <button class="rounded-lg p-3 text-left transition-all hover:scale-[1.02] hover:shadow-lg" style="background: rgb(15, 23, 42); border: 1px solid rgba(22, 163, 74, 0.267); cursor: pointer;">
                <div class="flex items-center justify-between mb-1">
                    <span style="color: rgb(248, 250, 252); font-size: 11px; font-weight: 600;">
                        Block C02
                    </span>
                    <span class="w-2 h-2 rounded-full" style="background: rgb(22, 163, 74);">
                    </span>
                </div>
                <div style="color: rgb(148, 163, 184); font-size: 10px;">
                    Z3
                </div>
                <div class="flex items-center justify-between mt-2">
                    <span style="color: rgb(22, 163, 74); font-size: 13px; font-weight: 700;">
                        31%
                    </span>
                    <span style="color: rgb(100, 116, 139); font-size: 10px;">
                        5/16
                    </span>
                </div>
                <div class="h-1 rounded-full mt-1" style="background: rgb(51, 65, 85);">
                    <div class="h-1 rounded-full" style="width: 31%; background: rgb(22, 163, 74);">
                    </div>
                </div>
                <div class="mt-1.5">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold" style="background: rgb(22, 163, 74); color: white; font-size: 11px;">
                        Bình thường
                    </span>
                </div>
            </button>
        </div>
    </div>
    <!-- Real-time Alarms Widget -->
    <div class="rounded-lg p-5 space-y-4" style="background: rgb(30, 41, 59); border: 1px solid rgb(51, 65, 85);">
        <div class="flex flex-wrap justify-between items-center gap-3 border-b border-slate-700 pb-3">
            <div class="flex items-center gap-2">
                <div class="relative flex h-2.5 w-2.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                </div>
                <h3 class="text-white text-sm font-bold font-mono uppercase tracking-wider">
                    Hệ thống Cảnh báo Thời gian thực (SCADA Alarms Live)
                </h3>
            </div>
            <span class="text-slate-400 text-[10px] font-mono bg-slate-950/65 px-2 py-0.5 rounded border border-slate-800">
                Chu kỳ cập nhật: 15s
            </span>
        </div>

        <!-- Alarm Type Summary Counters -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <!-- Operator Errors -->
            <div class="p-3 rounded-lg border bg-slate-950/40 border-amber-500/20 flex justify-between items-center">
                <div class="flex items-center gap-2.5">
                    <div class="p-2 rounded bg-amber-500/10 text-amber-400 border border-amber-500/20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><line x1="12" x2="12" y1="9" y2="13"></line><line x1="12" x2="12.01" y1="17" y2="17"></line></svg>
                    </div>
                    <div>
                        <span class="text-slate-400 text-[10px] uppercase font-mono block">Lỗi thao tác vận hành</span>
                        <span class="text-[9px] text-amber-400 font-mono">Operator Errors</span>
                    </div>
                </div>
                <span id="active-operator-count" class="text-xl font-bold text-amber-400 font-mono">0</span>
            </div>

            <!-- System Faults -->
            <div class="p-3 rounded-lg border bg-slate-950/40 border-red-500/20 flex justify-between items-center">
                <div class="flex items-center gap-2.5">
                    <div class="p-2 rounded bg-red-500/10 text-red-400 border border-red-500/20 animate-pulse">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
                    </div>
                    <div>
                        <span class="text-slate-400 text-[10px] uppercase font-mono block">Lỗi hệ thống / Thiết bị</span>
                        <span class="text-[9px] text-red-400 font-mono">System & Device Faults</span>
                    </div>
                </div>
                <span id="active-system-count" class="text-xl font-bold text-red-400 font-mono animate-pulse">0</span>
            </div>

            <!-- Maintenance Due -->
            <div class="p-3 rounded-lg border bg-slate-950/40 border-cyan-500/20 flex justify-between items-center">
                <div class="flex items-center gap-2.5">
                    <div class="p-2 rounded bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
                    </div>
                    <div>
                        <span class="text-slate-400 text-[10px] uppercase font-mono block">Thiết bị đến hạn bảo trì</span>
                        <span class="text-[9px] text-cyan-400 font-mono">Maintenance Due</span>
                    </div>
                </div>
                <span id="active-maint-count" class="text-xl font-bold text-cyan-400 font-mono">0</span>
            </div>
        </div>

        <!-- Alarms Live Feed Table -->
        <div class="overflow-x-auto bg-slate-950/20 rounded-lg border border-slate-800/80">
            <table class="w-full text-left border-collapse font-mono text-xs">
                <thead>
                    <tr class="border-b border-slate-800 text-slate-500 text-[10px] uppercase bg-slate-950/45">
                        <th class="py-2.5 px-3 font-semibold w-20">Thời gian</th>
                        <th class="py-2.5 px-3 font-semibold w-24">Mã Lỗi</th>
                        <th class="py-2.5 px-3 font-semibold w-40">Phân loại cảnh báo</th>
                        <th class="py-2.5 px-3 font-semibold w-32">Nguồn phát</th>
                        <th class="py-2.5 px-3 font-semibold">Nội dung chi tiết</th>
                        <th class="py-2.5 px-3 font-semibold text-center w-24">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="alarms-live-tbody" class="divide-y divide-slate-900/65">
                    <!-- Appended dynamically -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // CSS Keyframe styles for slide-down animation
    if (!document.getElementById('alarm-animation-styles')) {
        const style = document.createElement('style');
        style.id = 'alarm-animation-styles';
        style.innerHTML = `
            @@keyframes alarm-slide-down {
                from { opacity: 0; transform: translateY(-8px); }
                to { opacity: 1; transform: translateY(0); }
            }
            .alarm-row-new {
                animation: alarm-slide-down 0.4s ease-out forwards;
            }
        `;
        document.head.appendChild(style);
    }

    // Active alarms state
    let activeAlarms = [];

    // Pre-configured alarms generator database
    const operatorErrorsPool = [
        { code: "OP-ERR-01", msg: "Biển số xe đỗ lệch tâm khay nâng giới hạn an toàn" },
        { code: "OP-ERR-02", msg: "Nút bấm dừng khẩn cấp (E-Stop) kích hoạt đột ngột" },
        { code: "OP-ERR-03", msg: "Yêu cầu xuất xe thất bại - Phát hiện vật thể chuyển động vùng quét" },
        { code: "OP-ERR-04", msg: "Thẻ RFID không hợp lệ quẹt liên tiếp tại Barrier lối vào" },
        { code: "OP-ERR-05", msg: "Cố ý nhấn hạ mâm khi xe chưa vào đúng vị trí cơ cấu khóa" }
    ];

    const systemFaultsPool = [
        { code: "SYS-FLT-11", msg: "Mất kết nối truyền thông Modbus TCP với PLC chính" },
        { code: "SYS-FLT-12", msg: "Quá dòng động cơ nâng chính tời cuộn (Đo được: 15.2A)" },
        { code: "SYS-FLT-13", msg: "Cảm biến quang an toàn SafeGuard bị che khuất hoặc bụi bẩn" },
        { code: "SYS-FLT-14", msg: "Lỗi phản hồi công tắc giới hạn hành trình cuối LS-T3" },
        { code: "SYS-FLT-15", msg: "Điện áp nguồn cấp biến tần động cơ Shuttle vượt ngưỡng bảo vệ" }
    ];

    const maintenanceDuePool = [
        { code: "MNT-DUE-21", msg: "Pallet đỗ cơ khí đạt mốc hoạt động tần suất cao - Cần bôi trơn xích" },
        { code: "MNT-DUE-22", msg: "Cáp kéo tời nâng đạt giới hạn chu kỳ chạy - Đề xuất kiểm tra độ giãn" },
        { code: "MNT-DUE-23", msg: "Chổi than động cơ Shuttle mài mòn quá mốc 80% - Cần thay thế" },
        { code: "MNT-DUE-24", msg: "Ổ bi bạc đạn trục quay mâm xoay khô dầu - Yêu cầu bảo dưỡng" },
        { code: "MNT-DUE-25", msg: "Cần kiểm tra định kỳ chất lượng dầu thủy lực trạm nguồn nâng hạ" }
    ];

    // Helper to generate a random item from array
    function getRandomItem(arr) {
        return arr[Math.floor(Math.random() * arr.length)];
    }

    // Format current time as HH:mm:ss
    function formatCurrentTime() {
        const now = new Date();
        return now.toTimeString().split(' ')[0];
    }

    // Initialize initial alarms list (including reading localStorage for maintenance pallets)
    function initAlarms() {
        // 1. Check if there are pallets with cycles >= 100 in localStorage
        const storedCycles = localStorage.getItem('palletCycleData');
        let highCyclePallets = [];
        if (storedCycles) {
            try {
                const cycleData = JSON.parse(storedCycles);
                for (const [block, cyclesArray] of Object.entries(cycleData)) {
                    cyclesArray.forEach((cycles, idx) => {
                        if (cycles >= 100) {
                            highCyclePallets.push({
                                block: block,
                                pallet: `Pallet P${String(idx + 1).padStart(2, '0')}`,
                                cycles: cycles
                            });
                        }
                    });
                }
            } catch (e) {
                console.error("Lỗi đọc dữ liệu chu kỳ để sinh cảnh báo:", e);
            }
        }

        // Add any high cycle pallets as maintenance alarms
        highCyclePallets.forEach((p, index) => {
            const time = new Date();
            time.setMinutes(time.getMinutes() - (index * 4 + 2)); // slight offset in past
            const timeStr = time.toTimeString().split(' ')[0];
            
            // Extract Zone
            let zoneId = "Z1";
            if (p.block.includes("A-04") || p.block.includes("B-01") || p.block.includes("B-02")) zoneId = "Z2";
            else if (p.block.includes("B-03") || p.block.includes("B-04") || p.block.includes("C-01")) zoneId = "Z3";
            else if (p.block.includes("C-02") || p.block.includes("C-03") || p.block.includes("C-04")) zoneId = "Z4";
            else if (p.block.includes("D-01") || p.block.includes("D-02") || p.block.includes("D-03")) zoneId = "Z5";
            else if (p.block.includes("E-01") || p.block.includes("E-02") || p.block.includes("E-03")) zoneId = "Z6";

            activeAlarms.push({
                id: "ALM-" + Math.floor(100000 + Math.random() * 900000),
                time: timeStr,
                code: "MNT-DUE-100",
                type: 3, // Maintenance Due
                typeName: "Đến Hạn Bảo Trì",
                source: `${zoneId} · ${p.block} · ${p.pallet}`,
                msg: `${p.pallet} đã đạt ${p.cycles}/100 chu kỳ hoạt động - Yêu cầu bảo trì cơ học & reset`
            });
        });

        // Add some initial mock alarms if the list is short
        if (activeAlarms.length < 3) {
            activeAlarms.push({
                id: "ALM-382910",
                time: "22:50:15",
                code: "SYS-FLT-11",
                type: 2, // System Fault
                typeName: "Lỗi Hệ Thống",
                source: "Z2 · Block B-04 · Động cơ nâng",
                msg: "Lỗi chênh lệch nhiệt độ cuộn dây motor nâng hạ Block B04 quá tải (115°C)"
            });
            activeAlarms.push({
                id: "ALM-481023",
                time: "22:54:02",
                code: "OP-ERR-03",
                type: 1, // Operator Error
                typeName: "Lỗi Thao Tác",
                source: "Z1 · Block A-02 · Vùng an toàn",
                msg: "Lệnh xuất xe từ xa bị ngắt - Cảm biến quang phát hiện vật cản chuyển động tại lối ra"
            });
            activeAlarms.push({
                id: "ALM-582910",
                time: "22:56:45",
                code: "MNT-DUE-22",
                type: 3, // Maintenance Due
                typeName: "Đến Hạn Bảo Trì",
                source: "Z3 · Block C-01 · Xích tải",
                msg: "Pallet P08 đạt giới hạn chu kỳ bảo dưỡng định kỳ ổ bi đỡ ray dẫn hướng"
            });
        }

        renderAlarmsTable();
        updateCounters();
        updateGlobalBanner();
    }

    // Render active alarms table
    function renderAlarmsTable() {
        const tbody = document.getElementById('alarms-live-tbody');
        tbody.innerHTML = '';

        if (activeAlarms.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="6" class="py-8 text-center text-slate-500 italic">
                        Không có cảnh báo hoạt động. Hệ thống vận hành an toàn.
                    </td>
                </tr>
            `;
            return;
        }

        // Sort descending by time
        const sorted = [...activeAlarms].sort((a, b) => b.time.localeCompare(a.time));

        sorted.forEach(alm => {
            let typeBadge = "";
            let rowClass = "";
            let codeColor = "";

            if (alm.type === 1) { // Operator Error
                typeBadge = `<span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-amber-500/10 border border-amber-500/30 text-amber-400">LỖI THAO TÁC</span>`;
                rowClass = "bg-amber-955/5 hover:bg-amber-950/10 transition-colors";
                codeColor = "text-amber-500";
            } else if (alm.type === 2) { // System Fault
                typeBadge = `<span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-red-500/15 border border-red-500/30 text-red-400 animate-pulse">LỖI THIẾT BỊ</span>`;
                rowClass = "bg-red-955/5 hover:bg-red-955/10 transition-colors";
                codeColor = "text-red-500 font-bold";
            } else if (alm.type === 3) { // Maintenance Due
                typeBadge = `<span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-cyan-500/10 border border-cyan-500/30 text-cyan-400">ĐẾN HẠN BẢO TRÌ</span>`;
                rowClass = "bg-cyan-955/5 hover:bg-cyan-950/10 transition-colors";
                codeColor = "text-cyan-500";
            }

            const tr = document.createElement('tr');
            tr.id = `alarm-tr-${alm.id}`;
            tr.className = `${rowClass} border-b border-slate-900/60`;
            tr.innerHTML = `
                <td class="py-3 px-3 text-slate-400 text-[11px] font-mono">${alm.time}</td>
                <td class="py-3 px-3 ${codeColor} font-bold font-mono">${alm.code}</td>
                <td class="py-3 px-3">${typeBadge}</td>
                <td class="py-3 px-3 text-slate-300 font-semibold font-mono">${alm.source}</td>
                <td class="py-3 px-3 text-slate-200 max-w-sm truncate" title="${alm.msg}">${alm.msg}</td>
                <td class="py-3 px-3 text-center">
                    <button onclick="ackAlarm('${alm.id}')" class="px-2 py-1 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white rounded text-[10px] font-bold transition-all border border-slate-750 font-mono">
                        Xác nhận
                    </button>
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    // Update the counter stats
    function updateCounters() {
        const opCount = activeAlarms.filter(a => a.type === 1).length;
        const sysCount = activeAlarms.filter(a => a.type === 2).length;
        const maintCount = activeAlarms.filter(a => a.type === 3).length;

        document.getElementById('active-operator-count').textContent = opCount;
        document.getElementById('active-system-count').textContent = sysCount;
        document.getElementById('active-maint-count').textContent = maintCount;
    }

    // Update top dynamic banner
    function updateGlobalBanner() {
        const banner = document.getElementById('global-alarm-banner');
        const countSpan = document.getElementById('global-alarm-banner-count');
        const detailSpan = document.getElementById('global-alarm-banner-detail');

        if (activeAlarms.length > 0) {
            banner.classList.remove('hidden');
            countSpan.textContent = `${activeAlarms.length} cảnh báo đang hoạt động:`;
            
            // Get the latest alarm
            const sorted = [...activeAlarms].sort((a, b) => b.time.localeCompare(a.time));
            const latest = sorted[0];
            detailSpan.textContent = `[${latest.code}] ${latest.msg} (${latest.source})`;
        } else {
            banner.classList.add('hidden');
        }
    }

    // Ack (Acknowledge) alarm - remove it from list
    function ackAlarm(id) {
        const row = document.getElementById(`alarm-tr-${id}`);
        if (row) {
            // Apply fade out animation
            row.style.transition = 'all 0.3s ease';
            row.style.opacity = '0';
            row.style.transform = 'translateX(20px)';
            
            setTimeout(() => {
                activeAlarms = activeAlarms.filter(a => a.id !== id);
                renderAlarmsTable();
                updateCounters();
                updateGlobalBanner();
            }, 300);
        }
    }

    // Add alarm dynamically (real-time generator)
    function addRealtimeAlarm(type) {
        let code = "";
        let msg = "";
        let source = "";
        let typeName = "";

        const zone = "Z" + Math.floor(1 + Math.random() * 6);
        const block = "Block " + getRandomItem(["A-01", "A-02", "B-01", "B-04", "C-02", "D-01", "E-02"]);
        const pallet = "Pallet P" + String(Math.floor(1 + Math.random() * 12)).padStart(2, '0');

        if (type === 1) { // Operator Error
            const item = getRandomItem(operatorErrorsPool);
            code = item.code;
            msg = item.msg;
            source = `${zone} · ${block} · ${pallet}`;
            typeName = "Lỗi Thao Tác";
        } else if (type === 2) { // System Fault
            const item = getRandomItem(systemFaultsPool);
            code = item.code;
            msg = item.msg;
            source = `${zone} · ${block}`;
            typeName = "Lỗi Thiết Bị";
        } else { // Maintenance Due
            const item = getRandomItem(maintenanceDuePool);
            code = item.code;
            msg = item.msg;
            source = `${zone} · ${block} · ${pallet}`;
            typeName = "Đến Hạn Bảo Trì";
        }

        const newAlarm = {
            id: "ALM-" + Math.floor(100000 + Math.random() * 900000),
            time: formatCurrentTime(),
            code: code,
            type: type,
            typeName: typeName,
            source: source,
            msg: msg
        };

        // Add to active alarms
        activeAlarms.unshift(newAlarm);

        // Keep maximum of 8 alarms in live log list
        if (activeAlarms.length > 8) {
            activeAlarms.pop();
        }

        // Render & Update UI
        renderAlarmsTable();
        updateCounters();
        updateGlobalBanner();

        // Highlight the new row
        setTimeout(() => {
            const row = document.getElementById(`alarm-tr-${newAlarm.id}`);
            if (row) {
                row.classList.add('alarm-row-new');
                // Apply a glowing border highlight temporarily
                row.style.boxShadow = 'inset 0 0 10px rgba(59, 130, 246, 0.2)';
                setTimeout(() => {
                    row.style.boxShadow = 'none';
                }, 2000);
            }
        }, 50);
    }

    // Schedule real-time alarm generator loop (every 15 seconds)
    setInterval(() => {
        // Choose type randomly: 1 (Operator), 2 (System), 3 (Maintenance)
        // With weights: 40% System, 30% Operator, 30% Maintenance
        const rand = Math.random();
        let type = 2;
        if (rand < 0.3) {
            type = 1;
        } else if (rand < 0.6) {
            type = 3;
        }
        addRealtimeAlarm(type);
    }, 15000);

    // Initialize alarms on page load
    document.addEventListener("DOMContentLoaded", () => {
        initAlarms();
    });
</script>
</div>