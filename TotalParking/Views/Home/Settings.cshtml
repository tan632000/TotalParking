@{
    Layout = "~/Views/Shared/_ScadaLayout.cshtml";
}

<div class="p-6 pb-12 min-h-[calc(100vh-3.5rem)] text-slate-100" style="background: rgb(15, 23, 42); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="space-y-6">
        <!-- Header -->
        <div class="flex justify-between items-center pb-4 border-b border-slate-800">
            <div>
                <h1 class="text-2xl font-bold tracking-tight">Cấu hình hệ thống (Settings)</h1>
                <p class="text-slate-400 text-sm mt-1">Quản lý tham số truyền thông Modbus, kết nối cơ sở dữ liệu, phân phối cảnh báo và tích hợp API ngoài.</p>
            </div>
            <div class="flex gap-2">
                <button onclick="alert('Đã khôi phục cài đặt gốc về mặc định thành công!')" class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs bg-slate-800 hover:bg-slate-700 text-slate-350 border border-slate-700 transition-colors font-bold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-refresh-cw"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path><path d="M21 3v5h-5"></path><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path><path d="M8 16H3v5"></path></svg>
                    Khôi phục mặc định
                </button>
                <button onclick="alert('Đã lưu tất cả cấu hình hệ thống thành công!')" class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs bg-blue-600 hover:bg-blue-500 text-white border border-blue-500/50 transition-colors font-bold shadow-md">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-save"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"></path><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"></path><path d="M7 3v4a1 1 0 0 0 1 1h7"></path></svg>
                    Lưu cài đặt
                </button>
            </div>
        </div>

        <!-- Main Layout Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            <!-- 1. Modbus TCP & PLC Connections -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-xl space-y-4">
                <h3 class="text-white text-sm font-bold flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wifi text-blue-400"><path d="M12 20h.01"></path><path d="M2 8.82a15 15 0 0 1 20 0"></path><path d="M5 12.859a10 10 0 0 1 14 0"></path><path d="M8.5 16.429a5 5 0 0 1 7 0"></path></svg>
                    Kết nối truyền thông PLC/HMI
                </h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">IP SCADA Server (Lumi SCADA)</label>
                        <input type="text" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="192.168.1.100">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Port Modbus TCP</label>
                        <input type="number" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="502">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Chu kỳ Polling (ms)</label>
                        <input type="number" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="500">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Timeout kết nối (ms)</label>
                        <input type="number" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="3000">
                    </div>
                </div>
            </div>

            <!-- 2. Database config -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-xl space-y-4">
                <h3 class="text-white text-sm font-bold flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-database text-violet-400"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>
                    Cơ sở dữ liệu SCADA
                </h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">DB Host Address</label>
                        <input type="text" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="192.168.1.200">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">DB Name</label>
                        <input type="text" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="lumi_scada_tp">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Lưu trữ cảnh báo & sự kiện (ngày)</label>
                        <input type="number" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="730">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Tần suất tự động Backup (Giờ)</label>
                        <input type="number" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="12">
                    </div>
                </div>
            </div>

            <!-- 3. Alarms & Notifications -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-xl space-y-4">
                <h3 class="text-white text-sm font-bold flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell text-amber-400"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg>
                    Cảnh báo & SMS
                </h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Email nhận cảnh báo Critical</label>
                        <input type="text" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="admin@totalparking.vn">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">SMS nhận cảnh báo quá nhiệt motor</label>
                        <input type="text" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="+84901234567">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Ngưỡng báo động rung lắc (mm/s²)</label>
                        <input type="number" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="15">
                    </div>
                </div>
            </div>

            <!-- 4. Third-Party Webhook & Swagger API Docs (Upgrade requirement R24) -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-xl space-y-4">
                <h3 class="text-white text-sm font-bold flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-400"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                    Tích hợp API & Webhook (Third-Party)
                </h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Webhook URL gửi cảnh báo lỗi</label>
                        <input type="text" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-200 font-mono outline-none focus:border-blue-500 transition-colors" value="https://api.totalparking.vn/v1/webhook/alarms">
                    </div>
                    <div>
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Webhook Secret Authorization</label>
                        <input type="password" class="w-full bg-slate-800/60 border border-slate-700/50 rounded px-2.5 py-1.5 text-xs text-slate-250 font-mono outline-none focus:border-blue-500 transition-colors" value="secret_token_placeholder_scada_2026">
                    </div>
                    <div class="flex items-center gap-2 py-1">
                        <input type="checkbox" id="chkWebHookCritical" checked class="rounded bg-slate-800 border-slate-750">
                        <label for="chkWebHookCritical" class="text-slate-400 text-xs font-mono">Chỉ gửi cảnh báo nghiêm trọng</label>
                    </div>
                    <div class="pt-2 border-t border-slate-800">
                        <label class="text-slate-500 text-[10px] font-mono uppercase block mb-1">Swagger API Documentation</label>
                        <div class="flex items-center justify-between bg-slate-800/40 border border-slate-750 rounded p-2 text-xs">
                            <span class="text-slate-300 font-mono text-[10px] truncate">https://api.totalparking.vn/swagger/index.html</span>
                            <a href="https://api.totalparking.vn/swagger/index.html" target="_blank" class="text-blue-400 hover:text-blue-300 font-bold shrink-0 text-[11px] no-underline">Mở API Docs</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 5. UI/UX Options -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-xl space-y-4">
                <h3 class="text-white text-sm font-bold flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings text-slate-400"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    Tùy chọn giao diện vận hành
                </h3>
                <div class="space-y-3">
                    <div class="flex items-center justify-between">
                        <span class="text-slate-400 text-xs font-mono">Giao diện tối (Dark Mode)</span>
                        <button onclick="toggleSwitch(this)" class="w-10 h-5 rounded-full border transition-colors bg-blue-600 border-blue-500 relative flex items-center">
                            <div class="w-3.5 h-3.5 rounded-full bg-white transition-transform mx-0.5 translate-x-5"></div>
                        </button>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-400 text-xs font-mono">Tự động Ack alarm mức độ Thấp</span>
                        <button onclick="toggleSwitch(this)" class="w-10 h-5 rounded-full border transition-colors bg-slate-700 border-slate-650 relative flex items-center">
                            <div class="w-3.5 h-3.5 rounded-full bg-white transition-transform mx-0.5 translate-x-0"></div>
                        </button>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-400 text-xs font-mono">Bật thông báo còi / âm thanh</span>
                        <button onclick="toggleSwitch(this)" class="w-10 h-5 rounded-full border transition-colors bg-blue-600 border-blue-500 relative flex items-center">
                            <div class="w-3.5 h-3.5 rounded-full bg-white transition-transform mx-0.5 translate-x-5"></div>
                        </button>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-400 text-xs font-mono">Hiển thị timestamp thời gian thực</span>
                        <button onclick="toggleSwitch(this)" class="w-10 h-5 rounded-full border transition-colors bg-blue-600 border-blue-500 relative flex items-center">
                            <div class="w-3.5 h-3.5 rounded-full bg-white transition-transform mx-0.5 translate-x-5"></div>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 6. Hardware diagnostics (Non-functional R8/R9/R11 info) -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800 p-5 shadow-xl space-y-4">
                <h3 class="text-white text-sm font-bold flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock text-slate-400"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    Chẩn đoán Server & Tài nguyên
                </h3>
                <div class="space-y-2.5 text-xs font-mono">
                    <div class="flex justify-between items-center py-1 border-b border-slate-800/60">
                        <span class="text-slate-500 text-[10px] uppercase">SCADA Software Version</span>
                        <span class="text-slate-300 font-bold">v2.4.1</span>
                    </div>
                    <div class="flex justify-between items-center py-1 border-b border-slate-800/60">
                        <span class="text-slate-500 text-[10px] uppercase">Thời gian hoạt động (Uptime)</span>
                        <span class="text-emerald-400 font-bold">127 ngày 14 giờ 22 phút</span>
                    </div>
                    <div class="flex justify-between items-center py-1 border-b border-slate-800/60">
                        <span class="text-slate-500 text-[10px] uppercase">Tải CPU hiện tại</span>
                        <span class="text-slate-300 font-bold">23%</span>
                    </div>
                    <div class="flex justify-between items-center py-1 border-b border-slate-800/60">
                        <span class="text-slate-500 text-[10px] uppercase">Sử dụng RAM vật lý</span>
                        <span class="text-slate-300 font-bold">1.8 GB / 8.0 GB</span>
                    </div>
                    <div class="flex justify-between items-center py-1 border-b border-slate-800/60">
                        <span class="text-slate-500 text-[10px] uppercase">Kích thước cơ sở dữ liệu</span>
                        <span class="text-slate-300 font-bold text-amber-500">12.4 GB</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Toggle UI switch states
    function toggleSwitch(btn) {
        const dot = btn.querySelector("div");
        if (btn.classList.contains("bg-blue-600")) {
            btn.classList.remove("bg-blue-600", "border-blue-500");
            btn.classList.add("bg-slate-700", "border-slate-650");
            dot.classList.remove("translate-x-5");
            dot.classList.add("translate-x-0");
        } else {
            btn.classList.remove("bg-slate-700", "border-slate-650");
            btn.classList.add("bg-blue-600", "border-blue-500");
            dot.classList.remove("translate-x-0");
            dot.classList.add("translate-x-5");
        }
    }
</script>