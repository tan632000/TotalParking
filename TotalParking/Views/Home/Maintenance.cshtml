<script>
    // Tab switching for Maintenance page
    function switchMaintenanceTab(tabId) {
        const panels = document.querySelectorAll('.maintenance-panel');
        panels.forEach(p => p.classList.add('hidden'));
        
        document.getElementById('panel-maintenance-' + tabId).classList.remove('hidden');
        
        // Update tab buttons style
        const btnSchedule = document.getElementById('tab-btn-schedule');
        const btnDiag = document.getElementById('tab-btn-diagnostics');
        
        if (tabId === 'schedule') {
            btnSchedule.className = "px-4 py-2 border-b-2 font-bold text-xs tracking-wide transition-all duration-200 border-blue-500 text-blue-400 bg-transparent outline-none";
            btnDiag.className = "px-4 py-2 border-b-2 font-bold text-xs tracking-wide transition-all duration-200 border-transparent text-slate-400 hover:text-slate-200 hover:bg-slate-800/30 bg-transparent outline-none";
        } else {
            btnDiag.className = "px-4 py-2 border-b-2 font-bold text-xs tracking-wide transition-all duration-200 border-blue-500 text-blue-400 bg-transparent outline-none";
            btnSchedule.className = "px-4 py-2 border-b-2 font-bold text-xs tracking-wide transition-all duration-200 border-transparent text-slate-400 hover:text-slate-200 hover:bg-slate-800/30 bg-transparent outline-none";
            
            // Trigger block loading when switching to diagnostics first time
            if (!document.getElementById('diag-block').options.length) {
                updateDiagBlockOptions();
            }
        }
    }

    // Diagnostics Mock Database
