    let selectedDiagDevice = 'motor';

    function updateDiagBlockOptions() {
        const zone = document.getElementById('diag-zone').value;
        const blockSelect = document.getElementById('diag-block');
        blockSelect.innerHTML = '';
        
        let startNum = 1;
        if (zone === 'A') startNum = 1; // B01-B03
        else if (zone === 'B') startNum = 4; // B04-B06
        else if (zone === 'C') startNum = 7; // B07-B09
        else if (zone === 'D') startNum = 10; // B10-B12
        
        for (let i = 0; i < 3; i++) {
            const num = startNum + i;
            const blockId = 'B' + String(num).padStart(2, '0');
            const opt = document.createElement('option');
            opt.value = blockId;
            
            // Add label matching faults
            if (blockId === 'B01') opt.innerText = 'Block ' + blockId + ' (Hoạt động tốt)';
            else if (blockId === 'B04') opt.innerText = 'Block ' + blockId + ' (Lỗi Động Cơ)';
            else if (blockId === 'B02') opt.innerText = 'Block ' + blockId + ' (Cảnh báo Cảm biến HT)';
            else if (blockId === 'B03') opt.innerText = 'Block ' + blockId + ' (Lỗi Cửa An Toàn)';
            else opt.innerText = 'Block ' + blockId + ' (Hoạt động tốt)';
            
            blockSelect.appendChild(opt);
        }
        
        loadDiagBlock();
    }

    function getSelectedBlockData() {
        const blockId = document.getElementById('diag-block').value;
        if (blockDiagData[blockId]) {
            return blockDiagData[blockId];
        }
        // Fallback generator for normal blocks
        return {
            status: 'Normal',
            motor: { status: 'OK', name: 'ĐỘNG CƠ NÂNG HẠ ' + blockId, code: 'MTR-LIFT-' + blockId, temp: 52 + Math.floor(Math.random() * 8), current: 12.1, voltage: 380, speed: 1450, error: 'Không có lỗi', plc: { 'I:0/2 (LIFT_RUN)': 'ON', 'I:0/3 (LIFT_DIR)': 'UP', 'O:1/2 (RUN_CMD)': 'ON', 'O:1/3 (BRAKE_REL)': 'ON' } },
            shuttle: { status: 'OK', name: 'BÀN NÂNG & DI CHUYỂN ' + blockId, code: 'SHT-RUN-' + blockId, pos: 'Tầng 1 (Slot 02)', error: 'Không có lỗi', plc: { 'I:0/4 (SHT_POS)': 'ON', 'I:0/5 (SHT_HOME)': 'ON', 'O:1/4 (MOVE_FWD)': 'OFF', 'O:1/5 (MOVE_REV)': 'OFF' } },
            limitSwitch: { status: 'OK', name: 'CẢM BIẾN HÀNH TRÌNH TẦNG 1', code: 'LS-L1-' + blockId, value: 'Đã định vị chính xác', error: 'Không có lỗi', plc: { 'I:0/6 (LS_L1_ACT)': 'ON', 'I:0/7 (LS_L2_ACT)': 'OFF', 'I:0/8 (LS_L3_ACT)': 'OFF' } },
            photogate: { status: 'OK', name: 'CẢM BIẾN QUANG AN TOÀN', code: 'SAFE-PH-' + blockId, state: 'Thông suốt (Clear)', error: 'Không có lỗi', plc: { 'I:1/0 (PH_RX_OK)': 'ON', 'I:1/1 (PH_MUTE)': 'OFF', 'O:2/0 (ALARM_SIREN)': 'OFF' } }
        };
    }

    function loadDiagBlock() {
        const blockId = document.getElementById('diag-block').value;
        const data = getSelectedBlockData();
        
        // Update PLC status indicator
        const plcDot = document.getElementById('plc-status-dot');
        const plcText = document.getElementById('plc-status-text');
        
        if (data.status === 'Fault') {
            plcDot.className = 'w-2 h-2 rounded-full bg-red-500 animate-pulse';
            plcText.innerText = 'PLC Alert - Lỗi kích hoạt';
            plcText.className = 'text-red-400 font-mono text-[10px] font-bold';
        } else if (data.status === 'Warning') {
            plcDot.className = 'w-2 h-2 rounded-full bg-amber-500 animate-pulse';
            plcText.innerText = 'PLC Warning - Cảnh báo nhẹ';
            plcText.className = 'text-amber-400 font-mono text-[10px] font-bold';
        } else {
            plcDot.className = 'w-2 h-2 rounded-full bg-green-500 animate-pulse';
            plcText.innerText = 'PLC Connected - Sẵn sàng';
            plcText.className = 'text-green-400 font-mono text-[10px] font-bold';
        }
        
        // Render device status on diagram
        updateDiagDiagramNodeStatus('motor', data.motor.status, data.motor.temp + '°C');
        updateDiagDiagramNodeStatus('shuttle', data.shuttle.status, data.shuttle.pos);
        updateDiagDiagramNodeStatus('photogate', data.photogate.status, data.photogate.state.substring(0, 16) + '...');
        
        // Render limit switches nodes (3 nodes)
        updateDiagramLimitSwNodes(data.limitSwitch.status, blockId);
        
        // Refresh details panel
        clickDiagDevice(selectedDiagDevice);
    }

    function updateDiagDiagramNodeStatus(deviceId, status, valueText) {
        const node = document.getElementById('diag-device-' + deviceId);
        const stateText = document.getElementById('diag-device-' + deviceId + '-state');
        const statusSpan = document.getElementById('diag-device-' + deviceId + '-status');
        
        // Reset classes
        node.className = "bg-slate-900 border rounded-lg p-2.5 flex items-center gap-3 relative cursor-pointer transition-all hover:border-slate-700 w-full";
        
        if (status === 'FAULT') {
            node.classList.add('border-red-600/60', 'bg-red-950/10', 'shadow-[0_0_8px_rgba(239,68,68,0.25)]', 'animate-pulse');
            stateText.innerText = 'LỖI - ' + valueText;
            stateText.className = 'text-[9px] text-red-400 font-mono font-bold';
            statusSpan.innerText = '✗';
            statusSpan.className = 'absolute -top-1.5 -right-1.5 w-3.5 h-3.5 rounded-full flex items-center justify-center text-[8px] bg-red-600 border border-slate-950 text-white';
        } else if (status === 'WARNING') {
            node.classList.add('border-amber-600/60', 'bg-amber-950/10', 'shadow-[0_0_8px_rgba(245,158,11,0.25)]', 'animate-pulse');
            stateText.innerText = 'CẢNH BÁO - ' + valueText;
            stateText.className = 'text-[9px] text-amber-400 font-mono font-bold';
            statusSpan.innerText = '!';
            statusSpan.className = 'absolute -top-1.5 -right-1.5 w-3.5 h-3.5 rounded-full flex items-center justify-center text-[8px] bg-amber-500 border border-slate-950 text-slate-950 font-bold';
        } else {
            node.classList.add('border-slate-800');
            stateText.innerText = 'Bình thường - ' + valueText;
            stateText.className = 'text-[9px] text-green-400 font-mono';
            statusSpan.innerText = '✓';
            statusSpan.className = 'absolute -top-1.5 -right-1.5 w-3.5 h-3.5 rounded-full flex items-center justify-center text-[8px] bg-green-600 border border-slate-950 text-white';
        }
    }

    function updateDiagramLimitSwNodes(status, blockId) {
        const sw1 = document.getElementById('diag-device-limitsw-1');
        const sw2 = document.getElementById('diag-device-limitsw-2');
        const sw3 = document.getElementById('diag-device-limitsw-3');
        
        // Reset all to normal green
        sw1.className = 'device-node diag-ok';
        sw2.className = 'device-node diag-ok';
        sw3.className = 'device-node diag-ok';
        
        if (blockId === 'B02') {
            sw3.className = 'device-node diag-warning';
        } else if (blockId === 'B03') {
            // Normal
        }
    }

    function clickDiagDevice(deviceId, limitLevel = null) {
        selectedDiagDevice = deviceId;
        const data = getSelectedBlockData();
        
        // Remove selection outline from all nodes
        const nodes = ['motor', 'shuttle', 'photogate'];
        nodes.forEach(n => {
            document.getElementById('diag-device-' + n).style.outline = 'none';
        });
        document.getElementById('diag-device-limitsw-1').style.outline = 'none';
        document.getElementById('diag-device-limitsw-2').style.outline = 'none';
        document.getElementById('diag-device-limitsw-3').style.outline = 'none';
        
        // Highlight active node
        if (limitLevel) {
            document.getElementById('diag-device-limitsw-' + limitLevel).style.outline = '2px solid rgb(96, 165, 250)';
            selectedDiagDevice = 'limitSwitch';
        } else {
            document.getElementById('diag-device-' + deviceId).style.outline = '2px solid rgb(96, 165, 250)';
        }
        
        const panelTitle = document.getElementById('diag-panel-title');
        const panelSubtitle = document.getElementById('diag-panel-subtitle');
        const telemetryBox = document.getElementById('diag-panel-telemetry');
        const plcBox = document.getElementById('diag-panel-plc');
        const instructionBox = document.getElementById('diag-panel-instructions');
        const troubleBox = document.getElementById('diag-panel-trouble-box');
        
        let deviceData = null;
        if (selectedDiagDevice === 'motor') {
            deviceData = data.motor;
            panelTitle.innerText = 'Chi tiết: Động cơ nâng';
            panelSubtitle.innerText = 'Thiết bị: ' + deviceData.code + ' (Motor Lift)';
            
            telemetryBox.innerHTML = `
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850">
                    <span class="text-slate-500 text-[8px] block">Nhiệt độ cuộn dây</span>
                    <span class="${deviceData.temp > 100 ? 'text-red-400 font-bold' : 'text-slate-200'}">${deviceData.temp} °C</span>
                </div>
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850">
                    <span class="text-slate-500 text-[8px] block">Dòng điện Ampe</span>
                    <span class="${deviceData.current > 30 ? 'text-red-400 font-bold' : 'text-slate-200'}">${deviceData.current} A</span>
                </div>
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850">
                    <span class="text-slate-500 text-[8px] block">Điện áp pha</span>
                    <span class="text-slate-200">${deviceData.voltage} V</span>
                </div>
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850">
                    <span class="text-slate-500 text-[8px] block">Tốc độ vòng quay</span>
                    <span class="text-slate-200">${deviceData.speed} RPM</span>
                </div>
            `;
        } else if (selectedDiagDevice === 'shuttle') {
            deviceData = data.shuttle;
            panelTitle.innerText = 'Chi tiết: Bàn nâng / Shuttle';
            panelSubtitle.innerText = 'Thiết bị: ' + deviceData.code + ' (Pallet Runner)';
            
            telemetryBox.innerHTML = `
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850 col-span-2">
                    <span class="text-slate-500 text-[8px] block">Vị trí hiện tại</span>
                    <span class="text-slate-200">${deviceData.pos}</span>
                </div>
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850 col-span-2 mt-1">
                    <span class="text-slate-500 text-[8px] block">Tải trọng Pallet</span>
                    <span class="text-slate-200">1,820 kg (SUV/Sedan OK)</span>
                </div>
            `;
        } else if (selectedDiagDevice === 'limitSwitch') {
            deviceData = data.limitSwitch;
            const lvl = limitLevel || 1;
            panelTitle.innerText = 'Chi tiết: Cảm biến hành trình';
            panelSubtitle.innerText = 'Thiết bị: LS-L' + lvl + ' (Limit Switch)';
            
            telemetryBox.innerHTML = `
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850 col-span-2">
                    <span class="text-slate-500 text-[8px] block">Căn chỉnh hành trình</span>
                    <span class="${deviceData.status === 'WARNING' && lvl === 3 ? 'text-amber-400 font-bold' : 'text-slate-200'}">${lvl === 3 ? deviceData.value : 'Đã định vị chính xác'}</span>
                </div>
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850 col-span-2 mt-1">
                    <span class="text-slate-500 text-[8px] block">Chu kỳ kích hoạt</span>
                    <span class="text-slate-200">24,560 lượt đóng ngắt</span>
                </div>
            `;
        } else if (selectedDiagDevice === 'photogate') {
            deviceData = data.photogate;
            panelTitle.innerText = 'Chi tiết: Cảm biến an toàn';
            panelSubtitle.innerText = 'Thiết bị: ' + deviceData.code + ' (Safety Light Curtain)';
            
            telemetryBox.innerHTML = `
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850 col-span-2">
                    <span class="text-slate-500 text-[8px] block">Trạng thái luồng quang</span>
                    <span class="${deviceData.status === 'FAULT' ? 'text-red-400 font-bold' : 'text-slate-200'}">${deviceData.state}</span>
                </div>
                <div class="bg-slate-950/40 p-2 rounded border border-slate-850 col-span-2 mt-1">
                    <span class="text-slate-500 text-[8px] block">Độ căn chỉnh đầu thu-phát</span>
                    <span class="text-slate-200">${deviceData.status === 'FAULT' ? 'Lệch trục 4%' : 'Khớp 99.8%'}</span>
                </div>
            `;
        }
        
        // Render PLC I/O Registers
        let plcHtml = '';
        for (const [reg, state] of Object.entries(deviceData.plc)) {
            const isOff = state === 'OFF';
            const stateColor = isOff ? 'text-slate-500' : (state.includes('ON') ? 'text-green-400 font-bold' : 'text-amber-400');
            const stateDot = isOff ? 'bg-slate-700' : (state.includes('ON') ? 'bg-green-500 animate-pulse' : 'bg-amber-500');
            
            plcHtml += `
                <div class="flex justify-between items-center py-0.5">
                    <span class="text-slate-400">${reg}</span>
                    <span class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full ${stateDot}"></span>
                        <span class="${stateColor}">${state}</span>
                    </span>
                </div>
            `;
        }
        plcBox.innerHTML = plcHtml;
        
        // Troubleshooting Guide
        if (deviceData.status === 'FAULT' || deviceData.status === 'WARNING') {
            troubleBox.classList.remove('hidden');
            let guide = '';
            
            if (selectedDiagDevice === 'motor') {
                guide = `
                    <div class="text-[10px] text-red-400 font-bold mb-1">CẢNH BÁO LỖI: ${deviceData.error}</div>
                    <div>1. Tạm dừng Block lập tức để tránh cháy động cơ.</div>
                    <div>2. Điều hướng kỹ sư kiểm tra quạt làm mát động cơ nâng.</div>
                    <div>3. Thực hiện Bypass cảm biến nhiệt nếu nhiệt độ đo thực tế bình thường (Lỗi cảm biến).</div>
                    <div>4. Bấm "Reset PLC" sau khi đã kiểm tra an toàn.</div>
                `;
            } else if (selectedDiagDevice === 'limitSwitch') {
                guide = `
                    <div class="text-[10px] text-amber-400 font-bold mb-1">CẢNH BÁO LỆCH: ${deviceData.error}</div>
                    <div>1. Sensor hành trình T3 trễ tín hiệu, nghi ngờ lỏng ốc định vị cơ khí.</div>
                    <div>2. Bấm "Bypass Sensor" nếu cần vận hành khẩn cấp (cho phép PLC dùng Sensor hành trình dự phòng).</div>
                    <div>3. Tạo Work Order lập lịch kỹ thuật căn chỉnh tay vị trí vật lý.</div>
                `;
            } else if (selectedDiagDevice === 'photogate') {
                guide = `
                    <div class="text-[10px] text-red-400 font-bold mb-1">CẢNH BÁO AN TOÀN: ${deviceData.error}</div>
                    <div>1. Phát hiện vật cản (người, xe đỗ lệch khay hoặc rác).</div>
                    <div>2. Kiểm tra camera an toàn Zone để giám sát trực quan cửa hầm.</div>
                    <div>3. Sử dụng "Bypass Sensor" nếu cảm biến bị bám bụi và cần vận hành tạm thời.</div>
                    <div>4. Nhấn còi cảnh báo để cảnh báo người dùng.</div>
                `;
            }
            instructionBox.innerHTML = guide;
        } else {
            troubleBox.classList.add('hidden');
        }
    }

    // Remote Actions simulation
    function execDiagReset() {
        const blockId = document.getElementById('diag-block').value;
        const data = getSelectedBlockData();
        
        // Reset motor status
        if (data.motor.status === 'FAULT') {
            data.motor.status = 'OK';
            data.motor.temp = 68;
            data.motor.current = 14.1;
            data.motor.voltage = 380;
            data.motor.speed = 1450;
            data.motor.error = 'Không có lỗi';
            data.motor.plc = { 'I:0/2 (LIFT_RUN)': 'ON', 'I:0/3 (LIFT_DIR)': 'UP', 'O:1/2 (RUN_CMD)': 'ON', 'O:1/3 (BRAKE_REL)': 'ON' };
        }
        
        // Reset photogate status
        if (data.photogate.status === 'FAULT') {
            data.photogate.status = 'OK';
            data.photogate.state = 'Thông suốt (Clear)';
            data.photogate.error = 'Không có lỗi';
            data.photogate.plc = { 'I:1/0 (PH_RX_OK)': 'ON', 'I:1/1 (PH_MUTE)': 'OFF', 'O:2/0 (ALARM_SIREN)': 'OFF' };
        }
        
        // Reset limit switch status
        if (data.limitSwitch.status === 'WARNING') {
            data.limitSwitch.status = 'OK';
            data.limitSwitch.value = 'Đã định vị chính xác';
            data.limitSwitch.error = 'Không có lỗi';
            data.limitSwitch.plc = { 'I:0/6 (LS_L1_ACT)': 'OFF', 'I:0/7 (LS_L2_ACT)': 'OFF', 'I:0/8 (LS_L3_ACT)': 'ON' };
        }
        
        data.status = 'Normal';
        
        alert('Đã gửi lệnh Reset PLC và ACK cảnh báo lỗi thành công cho ' + blockId + '! Thiết bị đang hoạt động bình thường trở lại.');
        loadDiagBlock();
    }

    function execDiagBypass() {
        const blockId = document.getElementById('diag-block').value;
        const data = getSelectedBlockData();
        
        if (selectedDiagDevice === 'motor') {
            alert('Đã Bypass chế độ bảo vệ động cơ cho ' + blockId + '! Vận hành khẩn cấp được kích hoạt.');
        } else if (selectedDiagDevice === 'limitSwitch') {
            data.limitSwitch.status = 'OK';
            data.limitSwitch.value = 'Bypass Active (Forced)';
            data.limitSwitch.plc = { 'I:0/6 (LS_L1_ACT)': 'OFF', 'I:0/7 (LS_L2_ACT)': 'OFF', 'I:0/8 (LS_L3_ACT)': 'ON (Forced)' };
            alert('Đã gửi tín hiệu Bypass cảm biến hành trình T3. PLC chuyển sang chế độ cưỡng bức.');
            loadDiagBlock();
        } else if (selectedDiagDevice === 'photogate') {
            data.photogate.status = 'OK';
            data.photogate.state = 'Bypass Active (Forced)';
            data.photogate.plc = { 'I:1/0 (PH_RX_OK)': 'ON (Forced)', 'I:1/1 (PH_MUTE)': 'ON', 'O:2/0 (ALARM_SIREN)': 'OFF' };
            alert('Đã gửi tín hiệu Bypass cảm biến quang an toàn. PLC bỏ qua tín hiệu đứt luồng quang.');
            loadDiagBlock();
        }
    }

    function createDiagWorkOrder() {
        const blockId = document.getElementById('diag-block').value;
        const zone = document.getElementById('diag-zone').value;
        const data = getSelectedBlockData();
        
        let deviceName = '';
        let errorDesc = '';
        let priority = 'high';
        
        if (selectedDiagDevice === 'motor') {
            deviceName = 'Motor Nâng Hạ';
            errorDesc = data.motor.error;
            priority = 'urgent';
        } else if (selectedDiagDevice === 'shuttle') {
            deviceName = 'Bàn chuyển dịch / Shuttle';
            errorDesc = 'Bảo trì định kỳ / Tra dầu xích truyền động';
            priority = 'low';
        } else if (selectedDiagDevice === 'limitSwitch') {
            deviceName = 'Cảm biến hành trình';
            errorDesc = data.limitSwitch.error;
            priority = 'medium';
        } else if (selectedDiagDevice === 'photogate') {
            deviceName = 'Cảm biến an toàn';
            errorDesc = data.photogate.error;
            priority = 'high';
        }
        
        // Pre-populate Work Order List below
        const table = document.querySelector('table tbody');
        const newRow = table.insertRow(0);
        newRow.className = "border-b border-slate-800/60 hover:bg-slate-800/30";
        newRow.innerHTML = `
            <td class="px-3 py-2.5 text-slate-400">${zone}</td>
            <td class="px-3 py-2.5 text-slate-300">Block ${blockId}</td>
            <td class="px-3 py-2.5 text-slate-200 font-medium">${deviceName}</td>
            <td class="px-3 py-2.5 text-slate-400">Diag Remote</td>
            <td class="px-3 py-2.5"><span class="text-red-400">Active Fault</span></td>
            <td class="px-3 py-2.5 text-slate-500">10,000</td>
            <td class="px-3 py-2.5"><span class="text-slate-350">Diagnostics</span></td>
            <td class="px-3 py-2.5"><div class="text-slate-300">Hôm nay</div></td>
            <td class="px-3 py-2.5">
                <span class="inline-flex items-center px-1.5 py-0.5 rounded border text-[10px] font-mono font-medium ${priority === 'urgent' ? 'bg-red-950/60 border-red-700/50 text-red-300' : (priority === 'high' ? 'bg-orange-950/60 border-orange-700/50 text-orange-300' : 'bg-slate-950/60 border-slate-700/50 text-slate-300')}">
                    ${priority === 'urgent' ? 'Khẩn cấp' : (priority === 'high' ? 'Ưu tiên cao' : 'Thấp')}
                </span>
            </td>
        `;
        
        alert('Đã lập lệnh bảo trì khẩn cấp (Work Order) thành công cho thiết bị ' + deviceName + ' thuộc Block ' + blockId + '! Lệnh đã được đưa vào bảng theo dõi bên dưới.');
        
        // Switch to Schedule tab to see the new work order
        switchMaintenanceTab('schedule');
    }
</script>
