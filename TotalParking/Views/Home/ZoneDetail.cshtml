@{ Layout = "~/Views/Shared/_ScadaLayout.cshtml";

    int zoneId = ViewBag.ZoneId ?? 1;

    string zoneName = "Zone " + zoneId;

    string zoneLocation = "";

    string zoneColor = "rgb(37, 99, 235)"; // default blue

    string zoneColorMuted = "rgba(37, 99, 235, 0.15)";

    int totalSlots = 0;

    int occupiedSlots = 0;

    int availableSlots = 0;

    int errorSlots = 0;



    switch (zoneId)
    {
        case 1:
            zoneName = "Zone 1 (Zone A)";
            zoneLocation = "Hầm B1";
            zoneColor = "rgb(234, 179, 8)"; // yellow
            zoneColorMuted = "rgba(234, 179, 8, 0.15)";
            totalSlots = 34; occupiedSlots = 23; availableSlots = 11; errorSlots = 1;
            break;
        case 2:
            zoneName = "Zone 2 (Zone B)";
            zoneLocation = "Hầm B2";
            zoneColor = "rgb(148, 163, 184)"; // grey
            zoneColorMuted = "rgba(148, 163, 184, 0.15)";
            totalSlots = 38; occupiedSlots = 20; availableSlots = 18; errorSlots = 2;
            break;
        case 3:
            zoneName = "Zone 3 (Zone C)";
            zoneLocation = "Hầm B3";
            zoneColor = "rgb(249, 115, 22)"; // orange
            zoneColorMuted = "rgba(249, 115, 22, 0.15)";
            totalSlots = 40; occupiedSlots = 10; availableSlots = 30; errorSlots = 0;
            break;
        case 4:
            zoneName = "Zone 4 (Zone D)";
            zoneLocation = "Tầng 1";
            zoneColor = "rgb(168, 85, 247)"; // purple
            zoneColorMuted = "rgba(168, 85, 247, 0.15)";
            totalSlots = 44; occupiedSlots = 10; availableSlots = 34; errorSlots = 1;
            break;
        case 5:
            zoneName = "Zone 5 (Zone E)";
            zoneLocation = "Hầm B4";
            zoneColor = "rgb(6, 182, 212)"; // cyan
            zoneColorMuted = "rgba(6, 182, 212, 0.15)";
            totalSlots = 30; occupiedSlots = 15; availableSlots = 15; errorSlots = 0;
            break;
        case 6:
        default:
            zoneName = "Zone 6 (Zone F)";
            zoneLocation = "Tầng 2";
            zoneColor = "rgb(34, 197, 94)"; // green
            zoneColorMuted = "rgba(34, 197, 94, 0.15)";
            totalSlots = 35; occupiedSlots = 25; availableSlots = 10; errorSlots = 1;
            break;
    }

    int occupancyRate = (int)Math.Round((double)occupiedSlots / totalSlots * 100);

    var blocks = new List<dynamic>();
    if (zoneId == 1)
    {
        blocks.Add(new { Name = "Block A-01", Status = "Running", StatusText = "Đang chạy", Capacity = 12, Parked = 9, Suv = 4, Sedan = 5, Mode = "Tự động", ProgressColor = "rgb(37, 99, 235)", ProgressRate = 75, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block A-02", Status = "Normal", StatusText = "Bình thường", Capacity = 12, Parked = 6, Suv = 2, Sedan = 4, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 50, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block A-03", Status = "Warning", StatusText = "Cảnh báo", Capacity = 10, Parked = 8, Suv = 3, Sedan = 5, Mode = "Tự động", ProgressColor = "rgb(245, 158, 11)", ProgressRate = 80, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
    }
    else if (zoneId == 2)
    {
        blocks.Add(new { Name = "Block A-04", Status = "Error", StatusText = "Lỗi", Capacity = 10, Parked = 5, Suv = 2, Sedan = 3, Mode = "Tự động", ProgressColor = "rgb(220, 38, 38)", ProgressRate = 50, Dot1 = "bg-emerald-500", Dot2 = "bg-rose-500" });
        blocks.Add(new { Name = "Block B-01", Status = "Normal", StatusText = "Bình thường", Capacity = 14, Parked = 7, Suv = 3, Sedan = 4, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 50, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block B-02", Status = "Normal", StatusText = "Bình thường", Capacity = 14, Parked = 8, Suv = 3, Sedan = 5, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 57, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
    }
    else if (zoneId == 3)
    {
        blocks.Add(new { Name = "Block B-03", Status = "Maintenance", StatusText = "Bảo trì", Capacity = 12, Parked = 0, Suv = 0, Sedan = 0, Mode = "Bằng tay", ProgressColor = "rgb(124, 58, 237)", ProgressRate = 0, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block B-04", Status = "Normal", StatusText = "Bình thường", Capacity = 12, Parked = 5, Suv = 2, Sedan = 3, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 42, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block C-01", Status = "Normal", StatusText = "Bình thường", Capacity = 16, Parked = 5, Suv = 2, Sedan = 3, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 31, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
    }
    else if (zoneId == 4)
    {
        blocks.Add(new { Name = "Block C-02", Status = "Normal", StatusText = "Bình thường", Capacity = 16, Parked = 6, Suv = 2, Sedan = 4, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 38, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block C-03", Status = "Offline", StatusText = "Offline", Capacity = 14, Parked = 0, Suv = 0, Sedan = 0, Mode = "Bằng tay", ProgressColor = "rgb(100, 116, 139)", ProgressRate = 0, Dot1 = "bg-slate-500", Dot2 = "bg-slate-500" });
        blocks.Add(new { Name = "Block C-04", Status = "Normal", StatusText = "Bình thường", Capacity = 14, Parked = 4, Suv = 2, Sedan = 2, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 29, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
    }
    else if (zoneId == 5)
    {
        blocks.Add(new { Name = "Block D-01", Status = "Normal", StatusText = "Bình thường", Capacity = 10, Parked = 5, Suv = 2, Sedan = 3, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 50, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block D-02", Status = "Normal", StatusText = "Bình thường", Capacity = 10, Parked = 5, Suv = 2, Sedan = 3, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 50, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block D-03", Status = "Normal", StatusText = "Bình thường", Capacity = 10, Parked = 5, Suv = 2, Sedan = 3, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 50, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
    }
    else
    {
        blocks.Add(new { Name = "Block E-01", Status = "Normal", StatusText = "Bình thường", Capacity = 15, Parked = 10, Suv = 4, Sedan = 6, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 66, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block E-02", Status = "Normal", StatusText = "Bình thường", Capacity = 10, Parked = 8, Suv = 3, Sedan = 5, Mode = "Tự động", ProgressColor = "rgb(34, 197, 94)", ProgressRate = 80, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
        blocks.Add(new { Name = "Block E-03", Status = "Warning", StatusText = "Cảnh báo", Capacity = 10, Parked = 7, Suv = 3, Sedan = 4, Mode = "Tự động", ProgressColor = "rgb(245, 158, 11)", ProgressRate = 70, Dot1 = "bg-emerald-500", Dot2 = "bg-emerald-500" });
    }
}



<div class="p-5 pb-10 min-h-[calc(100vh-3.5rem)]">

    <div class="space-y-4">

        <!-- Top Navigation and Page Title (matches mockup header) -->

        <div class="flex justify-between items-center pb-2">

            <div>

                <div style="color: rgb(248, 250, 252); font-size: 16px; font-weight: 700;">Zone / Block Monitoring</div>

                <a href="@Url.Action("Zones", "Home", new { id = "" })" class="inline-flex items-center gap-1.5 text-slate-400 hover:text-white transition-colors mt-1.5 text-xs" style="text-decoration: none; white-space: nowrap;">

                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 14px; height: 14px; flex-shrink: 0; display: inline-block;" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />

                    </svg>

                    Quay lại bản đồ Zone

                </a>

            </div>

        </div>



        <div class="bg-card rounded border border-slate-700/50">

            <!-- Main Zone Header Card (Standalone box styled with background rgb(30, 41, 59) and border 1px solid rgb(51, 65, 85)) -->

            <div class="rounded-lg p-4 flex flex-row justify-between items-center shadow-lg" style="background: rgb(30, 41, 59); border: 1px solid rgb(51, 65, 85); font-family: Consolas, Monaco, monospace, sans-serif;">

                <div class="flex items-center gap-2 min-w-0">

                    <!-- Chevron down icon -->

                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 14px; height: 14px; flex-shrink: 0; display: inline-block;" class="text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />

                    </svg>

                    <span class="text-sm font-bold text-white shrink-0">@zoneName – @zoneLocation</span>

                    <span class="text-slate-500 shrink-0">|</span>

                    <span class="text-xs text-slate-300 font-medium shrink-0">3 blocks · @occupiedSlots/@totalSlots pallets · @occupancyRate%</span>

                </div>



                <div class="flex items-center gap-2.5 shrink-0">

                    <div class="w-24 bg-slate-800 h-1.5 rounded-full overflow-hidden" style="border-radius: 9999px; height: 6px;">

                        <div class="h-full rounded-full transition-all duration-500" style="width: @occupancyRate%; background-color: rgb(245, 158, 11); border-radius: 9999px; height: 6px;"></div>

                    </div>

                    <span class="text-xs font-bold text-amber-500">@occupancyRate%</span>

                </div>

            </div>



            <!-- 3 Blocks Grid (Matches mockup layout & styling) -->

            <div class="px-4 pb-4 border-t border-slate-700/40">

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3 mt-3">

                    @foreach (var block in blocks)

                    {

                        string cardClass = "";

                        string badgeStyle = "";

                        string modeStyle = "color: rgb(96, 165, 250);"; // blue for Tự động



                        switch ((string)block.Status)

                        {

                            case "Running":

                                cardClass = "status-running";

                                badgeStyle = "border: 1px solid rgba(37, 99, 235, 0.4); background: rgba(37, 99, 235, 0.1); color: rgb(96, 165, 250);";

                                break;

                            case "Normal":

                                cardClass = "status-normal";

                                badgeStyle = "border: 1px solid rgba(22, 163, 74, 0.4); background: rgba(22, 163, 74, 0.1); color: rgb(74, 222, 128);";

                                break;

                            case "Warning":

                                cardClass = "status-warning";

                                badgeStyle = "border: 1px solid rgba(245, 158, 11, 0.4); background: rgba(245, 158, 11, 0.1); color: rgb(251, 146, 60);";

                                break;

                            case "Error":

                                cardClass = "status-error";

                                badgeStyle = "border: 1px solid rgba(220, 38, 38, 0.4); background: rgba(220, 38, 38, 0.1); color: rgb(252, 165, 165);";

                                modeStyle = "color: rgb(148, 163, 184);"; // grey for Bằng tay

                                break;

                            case "Maintenance":

                                cardClass = "status-maintenance";

                                badgeStyle = "border: 1px solid rgba(124, 58, 237, 0.4); background: rgba(124, 58, 237, 0.1); color: rgb(192, 132, 252);";

                                modeStyle = "color: rgb(148, 163, 184);"; // grey for Bằng tay

                                break;

                            case "Offline":

                                cardClass = "status-offline";

                                badgeStyle = "border: 1px solid rgba(100, 116, 139, 0.4); background: rgba(100, 116, 139, 0.1); color: rgb(148, 163, 184);";

                                modeStyle = "color: rgb(148, 163, 184);";

                                break;

                        }



        <button onclick="openBlockModal('@block.Name', '@block.StatusText', '@block.Status', @block.Capacity, @block.Parked, @block.Suv, @block.Sedan, '@block.Mode', @block.ProgressRate, '@block.ProgressColor')"

                class="block-card-btn @cardClass">

            <div>

                <!-- Card Header (Block name & status badge) -->

                <div class="flex items-center justify-between mb-3.5">

                    <span class="font-bold text-white text-xs">@block.Name</span>

                    <span class="px-2 py-0.5 rounded text-[10px] font-semibold" style="@badgeStyle">@block.StatusText</span>

                </div>



                <!-- Inner telemetry fields (Sức chứa, Có xe, SUV/Sedan, Chế độ) -->

                <div class="space-y-2 text-[11px]">

                    <div class="flex justify-between items-center">

                        <span class="text-slate-400">Sức chứa</span>

                        <span class="font-semibold" style="color: rgb(248, 250, 252);">@block.Capacity</span>

                    </div>

                    <div class="flex justify-between items-center">

                        <span class="text-slate-400">Có xe</span>

                        <span class="font-bold" style="color: rgb(34, 197, 94);">@block.Parked</span>

                    </div>

                    <div class="flex justify-between items-center">

                        <span class="text-slate-400">SUV / Sedan</span>

                        <span class="font-semibold" style="color: rgb(248, 250, 252);">@block.Suv / @block.Sedan</span>

                    </div>

                    <div class="flex justify-between items-center">

                        <span class="text-slate-400">Chế độ</span>

                        <span style="@modeStyle" class="font-bold">@block.Mode</span>

                    </div>

                </div>

            </div>



            <!-- Progress Bar & Ratio/Percent (matches mockup details exactly) -->

            <div class="mt-4 pt-2 border-t border-[#23354E]/30">

                <div class="w-full bg-[#1E293B] h-1.5 rounded-full overflow-hidden" style="border-radius: 9999px; height: 6px;">

                    <div class="h-full rounded-full" style="width: @(block.ProgressRate)%; background-color: @block.ProgressColor; border-radius: 9999px; height: 6px;"></div>

                </div>

                <div class="flex justify-between text-[10px] font-semibold mt-1">

                    <span class="text-slate-500">@block.Parked/@block.Capacity</span>

                    <span style="color: @block.ProgressColor">@block.ProgressRate%</span>

                </div>



                <!-- PLC & HMI Status Dots -->

                <div class="flex gap-1.5 mt-2.5">

                    <span class="w-2.5 h-2.5 rounded-full inline-block" style="border-radius: 9999px; width: 8px; height: 8px; background-color: rgb(34, 197, 94);"></span>

                    <span class="w-2.5 h-2.5 rounded-full inline-block" style="border-radius: 9999px; width: 8px; height: 8px; background-color: rgb(34, 197, 94);"></span>

                </div>

            </div>

        </button>}

                </div>

            </div>

        </div>

    </div>



</div>



<!-- Block Details Modal Overlay (using custom CSS classes for absolute stability) -->

<div id="blockDetailModal" class="custom-modal-overlay">

    <!-- Modal Box -->

    <div class="custom-modal-box">

        <!-- Close Button -->

        <button onclick="closeBlockModal()" class="absolute-close-btn" aria-label="Close modal">

            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />

            </svg>

        </button>



        <!-- Header -->

        <div class="flex items-center gap-3 pb-3 border-b border-[#23354E]/55">

            <h2 id="modalBlockName" class="text-base font-bold text-white">Block A-01</h2>

            <span id="modalBlockStatus" class="px-2 py-0.5 rounded text-[10px] font-semibold border flex items-center gap-1">

                <!-- Populated dynamically -->

            </span>

        </div>



        <!-- 8 Stats Grid -->

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5 my-4">

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">ZONE</span>

                <span id="modalZoneVal" class="block text-xs font-bold text-white mt-0.5">Zone A</span>

            </div>

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">CHẾ ĐỘ</span>

                <span id="modalModeVal" class="block text-xs font-bold text-white mt-0.5">Tự động</span>

            </div>

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">SỨC CHỨA</span>

                <span id="modalCapacityVal" class="block text-xs font-bold text-white mt-0.5">12 pallet</span>

            </div>

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">CÓ XE</span>

                <span id="modalParkedVal" class="block text-xs font-bold text-white mt-0.5">9 (75%)</span>

            </div>

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">SUV</span>

                <span id="modalSuvVal" class="block text-xs font-bold text-white mt-0.5">4</span>

            </div>

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">SEDAN</span>

                <span id="modalSedanVal" class="block text-xs font-bold text-white mt-0.5">5</span>

            </div>

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">CHU KỲ</span>

                <span id="modalCycleVal" class="block text-xs font-bold text-white mt-0.5">3,820</span>

            </div>

            <div class="modal-stat-card">

                <span class="text-slate-500 text-[10px] font-mono uppercase">RUNTIME MOTOR</span>

                <span id="modalRuntimeVal" class="block text-xs font-bold text-white mt-0.5">1240h</span>

            </div>

        </div>



        <!-- Pallets Grid Container -->

        <div class="space-y-2.5">

            <div class="flex items-center gap-2 pt-4 pb-4">

                <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                    <circle cx="12" cy="12" r="10" />

                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7h4a3 3 0 0 1 0 6H9" />

                </svg>

                <span class="text-xs font-bold text-slate-300">Trạng thái Pallet (<span id="modalPalletCount">12 pallet</span>)</span>

            </div>



            <!-- Grid of Pallets (Using CSS Grid for perfect layout and alignment) -->

            <div id="modalPalletsGrid">

                <!-- Populated dynamically -->

            </div>

        </div>



        <!-- Legend -->

        <div class="flex flex-wrap gap-4 text-[10px] mt-4 pt-2 border-t border-[#23354E]/40 font-semibold">

            <div class="flex items-center gap-1.5">

                <span class="w-3 h-3 rounded inline-block" style="background-color: rgb(22, 163, 74);"></span>

                <span class="text-slate-300">Có xe (Xanh lá)</span>

            </div>

            <div class="flex items-center gap-1.5">

                <span class="w-3 h-3 rounded inline-block" style="background-color: rgb(226, 232, 240); border: 1px solid rgb(203, 213, 225);"></span>

                <span class="text-slate-300">Trống</span>

            </div>

            <div class="flex items-center gap-1.5">

                <span class="w-3 h-3 rounded inline-block" style="background-color: rgb(220, 38, 38);"></span>

                <span class="text-slate-300">Lỗi (Đỏ)</span>

            </div>

            @if (zoneId == 3)

            {

                <div class="flex items-center gap-1.5">

                    <span class="w-3 h-3 rounded inline-block" style="background-color: rgb(132, 204, 22);"></span>

                    <span class="text-slate-300">Xanh mạ</span>

                </div>

                <div class="flex items-center gap-1.5">

                    <span class="w-3 h-3 rounded inline-block" style="background-color: rgb(6, 182, 212);"></span>

                    <span class="text-slate-300">Xanh cyan</span>

                </div>

            }

            else

            {

                <div class="flex items-center gap-1.5">

                    <span class="w-3 h-3 rounded inline-block" style="background-color: rgb(124, 58, 237);"></span>

                    <span class="text-slate-300">Khóa</span>

                </div>

            }

        </div>



        <!-- Connection Status -->

        <div class="mt-4 pt-2 border-t border-[#23354E]/30">

            <div class="flex items-center gap-1.5 mb-2">

                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />

                </svg>

                <span class="text-xs font-bold text-slate-300">Trạng thái kết nối</span>

            </div>

            <div class="flex gap-4 text-xs font-bold">

                <div class="flex items-center gap-1.5">

                    <span class="w-2.5 h-2.5 rounded-full inline-block" style="background-color: rgb(34, 197, 94); box-shadow: rgba(34, 197, 94, 0.4) 0px 0px 6px;"></span>

                    <span class="text-slate-300">PLC</span>

                </div>

                <div class="flex items-center gap-1.5">

                    <span class="w-2.5 h-2.5 rounded-full inline-block" style="background-color: rgb(34, 197, 94); box-shadow: rgba(34, 197, 94, 0.4) 0px 0px 6px;"></span>

                    <span class="text-slate-300">HMI</span>

                </div>

            </div>

        </div>



        <!-- Footer Buttons (Uses white-space nowrap and shrink-0 to prevent layout wrapping and huge SVGs) -->

        <div class="flex flex-wrap gap-2 mt-5 pt-3 border-t border-[#23354E]/40">

            <!-- Lịch sử (slate grey) -->

