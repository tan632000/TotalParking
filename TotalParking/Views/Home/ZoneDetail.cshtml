<script>

    function openBlockModal(blockName, statusText, statusType, capacity, parked, suv, sedan, mode, progressRate, progressColor) {

        // 1. Set text values

        document.getElementById("modalBlockName").innerText = blockName;



        // 2. Set status badge

        var statusBadge = document.getElementById("modalBlockStatus");

        statusBadge.className = "px-2 py-0.5 rounded text-[10px] font-semibold border flex items-center gap-1";



        // Pulse/Activity zig-zag SVG line icon

        var pulseIcon = `<svg class="h-3 w-3 inline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`;



        if (statusType === "Running") {

            statusBadge.innerHTML = pulseIcon + " " + statusText;

            statusBadge.className += " border-[#2563eb]/40 bg-[#2563eb]/10 text-[#60a5fa]";

        } else if (statusType === "Normal") {

            statusBadge.innerHTML = "● " + statusText;

            statusBadge.className += " border-[#16a34a]/40 bg-[#16a34a]/10 text-[#4ade80]";

        } else if (statusType === "Warning") {

            statusBadge.innerHTML = "▲ " + statusText;

            statusBadge.className += " border-[#d97706]/40 bg-[#d97706]/10 text-[#fb923c]";

        } else if (statusType === "Error") {

            statusBadge.innerHTML = "⚠ " + statusText;

            statusBadge.className += " border-[#dc2626]/40 bg-[#dc2626]/10 text-[#fca5a5]";

        } else if (statusType === "Maintenance") {

            statusBadge.innerHTML = "🔧 " + statusText;

            statusBadge.className += " border-[#7c3aed]/40 bg-[#7c3aed]/10 text-[#c084fc]";

        } else if (statusType === "Offline") {

            statusBadge.innerHTML = "🔌 " + statusText;

            statusBadge.className += " border-[#64748b]/40 bg-[#64748b]/10 text-[#94a3b8]";

        }



        // 3. Stats Grid

        document.getElementById("modalZoneVal").innerText = "@zoneName";

        document.getElementById("modalModeVal").innerText = mode;

        document.getElementById("modalCapacityVal").innerText = capacity + " pallet";

        document.getElementById("modalParkedVal").innerText = parked + " (" + progressRate + "%)";

        document.getElementById("modalSuvVal").innerText = suv;

        document.getElementById("modalSedanVal").innerText = sedan;



        // Cycles & Runtime simulation

        var isBlock1 = blockName.endsWith("-01");

        var isBlock2 = blockName.endsWith("-02");

        var isBlock3 = blockName.endsWith("-03");



        var cycleVal = isBlock1 ? "3,820" : (isBlock2 ? "2,450" : (isBlock3 ? "1,980" : "890"));

        var runtimeVal = isBlock1 ? "1240h" : (isBlock2 ? "850h" : (isBlock3 ? "640h" : "310h"));



        document.getElementById("modalCycleVal").innerText = cycleVal;

        document.getElementById("modalRuntimeVal").innerText = runtimeVal;

        document.getElementById("modalPalletCount").innerText = capacity + " pallet";



        // 4. Generate Pallets Grid

        var grid = document.getElementById("modalPalletsGrid");

        grid.innerHTML = "";



        // Standard plate lists to display beautiful Vietnamese licenses

        var plates = ["51G-12345", "30H-88877", "43A-56789", "92B-11223", "79C-44556", "51K-99001", "34A-65432", "51F-77788", "29A-99999"];

        var times = ["06:00", "08:13", "10:26", "12:39", "14:52", "16:05", "06:18", "08:31", "10:44"];



        for (var i = 1; i <= capacity; i++) {

            var slotNumber = i;

            var numStr = slotNumber < 10 ? "0" + slotNumber : slotNumber;

            var pCode = "P" + numStr;



            var type = "";

            var plate = "";

            var time = "";



            var isOccupied = false;

            var isError = false;

            var isLocked = false;



            if (i <= parked) {

                isOccupied = true;

                // Distribute SUV and Sedan based on block stats

                type = (i <= suv) ? "SUV" : "Sedan";

                plate = plates[(i - 1) % plates.length];

                time = times[(i - 1) % times.length];

            } else if (statusType === "Error" && i === capacity) {

                isError = true;

            } else if (statusType === "Maintenance" || statusType === "Offline") {

                isLocked = true;

            } else if (statusType === "Warning" && i === capacity - 1) {

                isError = true;

            } else if (i === capacity) {

                isLocked = true;

            }



            var card = document.createElement("div");



            if (isOccupied) {

                card.className = "pallet-card occupied";

                card.innerHTML = `

                    <div class="pallet-header">

                        <svg style="width: 12px; height: 12px; flex-shrink: 0; display: inline-block; color: rgb(74, 222, 128);" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2" />

                            <circle cx="7" cy="17" r="2" />

                            <circle cx="17" cy="17" r="2" />

                        </svg>

                        <span>${pCode}</span>

                    </div>

                    <div class="pallet-type">${type}</div>

                    <div class="pallet-plate" style="color: rgb(74, 222, 128);">${plate}</div>

                    <div class="pallet-time" style="color: rgb(22, 163, 74);">${time}</div>

                `;

            } else if (isError) {

                card.className = "pallet-card error";

                card.innerHTML = `

                    <div class="pallet-header" style="height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 6px;">

                        <svg style="width: 14px; height: 14px; flex-shrink: 0; display: inline-block; color: rgb(248, 113, 113);" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />

                        </svg>

                        <span>${pCode}</span>

                    </div>

                `;

            } else if (isLocked) {

                card.className = "pallet-card locked";

                card.innerHTML = `

                    <div class="pallet-header" style="height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 6px;">

                        <svg style="width: 14px; height: 14px; flex-shrink: 0; display: inline-block; color: rgb(192, 132, 252);" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2zm10-10V7a4 4 0 0 0-8 0v4h8z" />

                        </svg>

                        <span>${pCode}</span>

                    </div>

                `;

            } else {

                card.className = "pallet-card empty";

                card.innerHTML = `

                    <div class="pallet-header" style="height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 6px;">

                        <svg style="width: 12px; height: 12px; flex-shrink: 0; display: inline-block; color: rgb(203, 213, 225);" fill="none" viewBox="0 0 24 24" stroke="currentColor">

                            <circle cx="12" cy="12" r="10" />

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7h4a3 3 0 0 1 0 6H9" />

                        </svg>

                        <span>${pCode}</span>

                    </div>

                `;

            }



            grid.appendChild(card);

        }



        // 5. Open modal

        var modal = document.getElementById("blockDetailModal");

        modal.classList.add("active");

    }



    function closeBlockModal() {

        var modal = document.getElementById("blockDetailModal");

        modal.classList.remove("active");

    }



    // Close on click outside modal content

    document.getElementById("blockDetailModal").addEventListener("click", function(event) {

        if (event.target === this) {

            closeBlockModal();

        }

    });

</script>

