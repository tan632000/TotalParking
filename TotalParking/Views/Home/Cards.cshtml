                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-database"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>
                </div>
            </div>

            <!-- Active Cards -->
            <div class="bg-slate-900/50 rounded-xl border border-emerald-500/15 p-4 shadow-md flex items-center justify-between transition-all duration-300 hover:scale-[1.01] hover:border-emerald-500/35 shadow-[0_0_8px_rgba(16,185,129,0.02)]">
