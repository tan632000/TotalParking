                    <div class="text-emerald-400 text-xs font-mono uppercase tracking-wider">THẺ ĐANG HOẠT ĐỘNG</div>
                    <div id="kpiActiveCards" class="text-emerald-300 text-2xl font-mono font-bold leading-none">4</div>
                </div>
                <div class="p-2.5 rounded-lg bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
