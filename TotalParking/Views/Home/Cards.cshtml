<!-- Add New Card Modal Overlay -->
<div id="newCardModal" class="card-modal-overlay">
    <div class="card-modal-box">
        <!-- Close Button -->
        <button onclick="closeNewCardModal()" class="absolute-close-btn" aria-label="Close modal">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>

        <h3 class="text-white text-base font-bold pb-3 border-b border-slate-800 mb-4">Cài đặt đăng ký thẻ từ mới</h3>
        
        <!-- Registration Form -->
        <form id="newCardForm" onsubmit="submitNewCard(event)" class="space-y-4 text-xs">
            <div class="space-y-1.5">
                <label class="text-slate-400 font-semibold block">Mã thẻ từ (RFID Card ID)</label>
                <input id="inputCardId" type="text" placeholder="Ví dụ: TH-01300" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-slate-200 outline-none focus:border-blue-500 font-mono">
            </div>

            <div class="space-y-1.5">
                <label class="text-slate-400 font-semibold block">Biển số xe định danh</label>
                <input id="inputPlate" type="text" placeholder="Ví dụ: 30K-99999" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-slate-200 outline-none focus:border-blue-500 font-mono">
            </div>

            <div class="space-y-1.5">
                <label class="text-slate-400 font-semibold block">Họ và tên chủ xe</label>
                <input id="inputOwner" type="text" placeholder="Ví dụ: Nguyễn Văn Cường" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-slate-200 outline-none focus:border-blue-500">
            </div>

            <div class="space-y-1.5">
                <label class="text-slate-400 font-semibold block">Loại xe đăng ký</label>
                <select id="selectVehicleType" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-slate-200 outline-none focus:border-blue-500 font-mono">
                    <option value="Sedan">Sedan (Gầm thấp)</option>
                    <option value="SUV">SUV (Gầm cao)</option>
                </select>
            </div>

            <div class="space-y-1.5">
                <label class="text-slate-400 font-semibold block">Phân khu (Zone)</label>
                <select id="selectZone" onchange="updateModalBlockOptions()" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-slate-200 outline-none focus:border-blue-500 font-mono">
                    <option value="1">Zone 1 (Hầm B1)</option>
                    <option value="2">Zone 2 (Hầm B2)</option>
                    <option value="3">Zone 3 (Hầm B3)</option>
                    <option value="4">Zone 4 (Tầng 1)</option>
                    <option value="5">Zone 5 (Hầm B4)</option>
                    <option value="6">Zone 6 (Tầng 2)</option>
                </select>
            </div>

            <div class="space-y-1.5">
                <label class="text-slate-400 font-semibold block">Block HMI đích để đồng bộ</label>
                <select id="selectBlock" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-slate-200 outline-none focus:border-blue-500 font-mono">
                    <!-- Options generated dynamically -->
                </select>
            </div>

            <!-- Submit Button -->
            <div class="pt-3 flex justify-end gap-2 border-t border-slate-800">
                <button type="button" onclick="closeNewCardModal()" class="px-4 py-2 rounded bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold transition-all">Hủy bỏ</button>
                <button type="submit" class="px-4 py-2 rounded bg-blue-600 hover:bg-blue-500 text-white font-bold transition-all shadow-md">Đăng ký & Đồng bộ</button>
            </div>
        </form>
    </div>
</div>

<style>
    /* Premium Modal overlay rules */
    .card-modal-overlay {
        position: fixed !important;
        inset: 0 !important;
        z-index: 9999 !important;
        display: none !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 16px !important;
        background-color: rgba(15, 23, 42, 0.85) !important;
        backdrop-filter: blur(5px) !important;
        transition: all 0.2s ease-in-out !important;
    }

    .card-modal-overlay.active {
        display: flex !important;
    }

    .card-modal-box {
        width: 100% !important;
        max-width: 440px !important;
        background-color: rgb(21, 32, 51) !important;
        border: 1px solid rgb(35, 53, 78) !important;
        border-radius: 12px !important;
        padding: 24px !important;
        box-sizing: border-box !important;
        position: relative !important;
        display: flex !important;
        flex-direction: column !important;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6) !important;
        animation: modalSlideUp 0.2s ease-out !important;
    }

    @@keyframes modalSlideUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .absolute-close-btn {
        position: absolute;
        top: 16px;
        right: 16px;
        background: transparent;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 4px;
        border-radius: 4px;
        transition: color 0.15s, background-color 0.15s;
    }

    .absolute-close-btn:hover {
        color: #ffffff;
        background-color: rgba(255, 255, 255, 0.08);
    }
</style>

<script>
    const zoneBlocksMap = {
        "1": ["Block A-01", "Block A-02", "Block A-03"],
        "2": ["Block A-04", "Block B-01", "Block B-02"],
        "3": ["Block B-03", "Block B-04", "Block C-01"],
        "4": ["Block C-02", "Block C-03", "Block C-04"],
        "5": ["Block D-01", "Block D-02", "Block D-03"],
        "6": ["Block E-01", "Block E-02", "Block E-03"]
    };

    // Populate modal blocks dropdown dynamically
    function updateModalBlockOptions() {
        const zoneId = document.getElementById("selectZone").value;
        const blocksList = zoneBlocksMap[zoneId] || [];
        const blockSelect = document.getElementById("selectBlock");
        
        blockSelect.innerHTML = '';
        blocksList.forEach(block => {
            const opt = document.createElement("option");
            opt.value = block;
            opt.textContent = block;
            blockSelect.appendChild(opt);
        });
    }

    // Live filter card list
    function filterCards() {
        const query = document.getElementById("cardSearchInput").value.toLowerCase().trim();
        const rows = document.querySelectorAll(".card-row");
        
        rows.forEach(row => {
            if (row.innerText.toLowerCase().includes(query)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

    // Toggle card block/unblock status
    function toggleCardStatus(btn) {
        const row = btn.closest("tr");
        const cardId = row.cells[0].innerText;
        const blockName = row.cells[5].innerText;
        const statusSpan = row.cells[6].querySelector("span");
        const syncSpan = row.cells[7].querySelector("span");
        
        btn.disabled = true;
        const siblingBtn = btn.nextElementSibling || btn.previousElementSibling;
        if (siblingBtn) siblingBtn.disabled = true;

        let progress = 0;
        const isLocking = (btn.innerText.includes("Khóa"));
        
        syncSpan.className = "inline-flex items-center gap-1 text-amber-500 font-bold text-[10px] animate-pulse";
        
        const interval = setInterval(() => {
            progress += 25;
            syncSpan.innerText = `⟳ HMI SYNC: ${progress}%`;
            
            if (progress >= 100) {
                clearInterval(interval);
                btn.disabled = false;
                if (siblingBtn) siblingBtn.disabled = false;

                if (isLocking) {
                    statusSpan.innerText = "Đã khóa";
                    statusSpan.className = "px-1.5 py-0.5 rounded border text-[9px] font-bold bg-red-950/60 border-red-700/50 text-red-400";
                    syncSpan.innerText = "⚠ ĐÃ KHÓA HMI";
                    syncSpan.className = "inline-flex items-center gap-1 text-red-500 font-bold text-[10px]";
                    btn.innerText = "Mở khóa";
                    row.classList.add("bg-red-950/5");
                    alert(`Đã hoàn tất đồng bộ lệnh KHÓA thẻ ${cardId} tới HMI Block ${blockName}.`);
                } else {
                    statusSpan.innerText = "Hoạt động";
                    statusSpan.className = "px-1.5 py-0.5 rounded border text-[9px] font-bold bg-green-950/60 border-green-700/50 text-green-400";
                    syncSpan.innerText = "● ĐÃ ĐỒNG BỘ";
                    syncSpan.className = "inline-flex items-center gap-1 text-emerald-400 font-bold text-[10px]";
                    btn.innerText = "Khóa";
                    row.classList.remove("bg-red-950/5");
                    alert(`Đã hoàn tất đồng bộ lệnh MỞ KHÓA thẻ ${cardId} tới HMI Block ${blockName}.`);
                }
                updateKPIs();
            }
        }, 400);
    }

    // Delete card row
    function deleteCardRow(btn) {
        const row = btn.closest("tr");
        const cardId = row.cells[0].innerText;
        const blockName = row.cells[5].innerText;

        if (confirm(`Bạn có chắc chắn muốn xóa thẻ ${cardId} và đồng bộ thu hồi thẻ này khỏi HMI Block ${blockName}?`)) {
            // Disable buttons
            const actionBtns = row.querySelectorAll("button");
            actionBtns.forEach(b => b.disabled = true);
            
            const syncSpan = row.cells[7].querySelector("span");
            syncSpan.className = "inline-flex items-center gap-1 text-amber-500 font-bold text-[10px] animate-pulse";
            
            let progress = 0;
            const interval = setInterval(() => {
                progress += 20;
                syncSpan.innerText = `⟳ XÓA HMI: ${progress}%`;
                
                if (progress >= 100) {
                    clearInterval(interval);
                    alert(`Đã thu hồi thành công thẻ từ ${cardId} khỏi HMI Block ${blockName} và xóa khỏi cơ sở dữ liệu SCADA.`);
                    row.remove();
                    updateKPIs();
                }
            }, 400);
        }
    }

    // Open/Close dialog new card
    function openNewCardModal() {
        document.getElementById("newCardModal").classList.add("active");
        updateModalBlockOptions();
    }

    // Close dialog new card
    function closeNewCardModal() {
        document.getElementById("newCardModal").classList.remove("active");
        document.getElementById("newCardForm").reset();
    }

    // Submit new card
    function submitNewCard(e) {
        e.preventDefault();
        
        const cardId = document.getElementById("inputCardId").value.trim().toUpperCase();
        const plate = document.getElementById("inputPlate").value.trim().toUpperCase();
        const owner = document.getElementById("inputOwner").value.trim();
        const vehicleType = document.getElementById("selectVehicleType").value;
        const zoneVal = document.getElementById("selectZone").value;
        const blockVal = document.getElementById("selectBlock").value;
        
        // Append new row to table
        const tbody = document.getElementById("cardsTableBody");
        const newRow = document.createElement("tr");
        newRow.className = "card-row border-b border-slate-850 hover:bg-slate-800/10";
        newRow.innerHTML = `
            <td class="px-4 py-3 text-blue-300 font-bold whitespace-nowrap">${cardId}</td>
            <td class="px-4 py-3 text-slate-200 font-bold">${plate}</td>
            <td class="px-4 py-3 text-slate-300">${owner}</td>
            <td class="px-4 py-3 text-slate-400">${vehicleType}</td>
            <td class="px-4 py-3 text-slate-400">Zone ${zoneVal}</td>
            <td class="px-4 py-3 text-slate-400">${blockVal}</td>
            <td class="px-4 py-3">
                <span class="px-1.5 py-0.5 rounded border text-[9px] font-bold bg-green-950/60 border-green-700/50 text-green-400">Hoạt động</span>
            </td>
            <td class="px-4 py-3">
                <span class="inline-flex items-center gap-1 text-amber-500 font-bold text-[10px] animate-pulse">
                    ⟳ HMI SYNC: 0%
                </span>
            </td>
            <td class="px-4 py-3 text-slate-500">—</td>
            <td class="px-4 py-3 text-center">
                <div class="flex justify-center gap-2">
                    <button onclick="toggleCardStatus(this)" class="px-2 py-0.5 rounded border border-slate-700 hover:border-amber-500 hover:text-amber-400 text-slate-400 transition-colors" disabled>Khóa</button>
                    <button onclick="deleteCardRow(this)" class="px-2 py-0.5 rounded border border-slate-700 hover:border-red-500 hover:text-red-400 text-slate-400 transition-colors" disabled>Xóa</button>
                </div>
            </td>
        `;
        
        tbody.appendChild(newRow);
        closeNewCardModal();
        updateKPIs();
        
        let progress = 0;
        const interval = setInterval(() => {
            progress += 20;
            const syncSpan = newRow.cells[7].querySelector("span");
            if (syncSpan) {
                syncSpan.innerText = `⟳ HMI SYNC: ${progress}%`;
            }
            
            if (progress >= 100) {
                clearInterval(interval);
                if (syncSpan) {
                    syncSpan.innerText = "● ĐÃ ĐỒNG BỘ";
                    syncSpan.className = "inline-flex items-center gap-1 text-emerald-400 font-bold text-[10px]";
                }
                const actionBtns = newRow.querySelectorAll("button");
                actionBtns.forEach(btn => btn.disabled = false);
            }
        }, 500);
        
        alert(`Đã khởi tạo đăng ký thẻ ${cardId} gắn với xe ${plate}. Bắt đầu đồng bộ HMI tới ${blockVal}...`);
    }

    // Update KPIs count
    function updateKPIs() {
        const rows = document.querySelectorAll(".card-row");
        let activeCount = 0;
        let lockedCount = 0;
        
        rows.forEach(row => {
            const statusSpan = row.cells[6].querySelector("span");
            if (statusSpan) {
                const status = statusSpan.innerText;
                if (status === "Hoạt động") {
                    activeCount++;
                } else {
                    lockedCount++;
                }
            }
        });
        
        document.getElementById("kpiTotalCards").innerText = rows.length;
        document.getElementById("kpiActiveCards").innerText = activeCount;
        document.getElementById("kpiLockedCards").innerText = lockedCount;
    }
</script>