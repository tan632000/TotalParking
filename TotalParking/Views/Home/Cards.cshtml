@{
    Layout = "~/Views/Shared/_ScadaLayout.cshtml";
}

<div class="p-6 pb-12 min-h-[calc(100vh-3.5rem)] text-slate-100" style="background: rgb(15, 23, 42); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="space-y-6">
        <!-- Header -->
        <div class="flex justify-between items-center pb-4 border-b border-slate-800">
            <div>
                <h1 class="text-2xl font-bold tracking-tight">Quản lý thẻ từ bãi đỗ (RFID Card Management)</h1>
                <p class="text-slate-400 text-sm mt-1">Đăng ký thẻ từ, thiết lập biển số xe định danh, giám sát trạng thái đồng bộ dữ liệu xuống HMI tại từng block vật lý.</p>
            </div>
            <button onclick="openNewCardModal()" class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs bg-blue-600 hover:bg-blue-500 text-white border border-blue-500/50 transition-colors font-bold shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                Cài đặt thẻ mới
            </button>
        </div>

        <!-- KPI widgets -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Total Cards -->
            <div class="bg-slate-900/50 rounded-xl border border-slate-800/80 p-4 shadow-md flex items-center justify-between transition-all duration-300 hover:scale-[1.01] hover:border-slate-700/60">
                <div class="space-y-1">
                    <div class="text-slate-500 text-xs font-mono uppercase tracking-wider">TỔNG SỐ THẺ ĐANG QUẢN LÝ</div>
                    <div id="kpiTotalCards" class="text-slate-100 text-2xl font-mono font-bold leading-none">5</div>
                </div>
