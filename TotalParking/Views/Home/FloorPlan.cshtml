@{
    Layout = "~/Views/Shared/_ScadaLayout.cshtml";
}

<div class="p-6 pb-12 min-h-[calc(100vh-3.5rem)] text-slate-100" style="background: rgb(15, 23, 42); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="space-y-6">
        <!-- Top Title Panel matching Mockup -->
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 pb-4 border-b border-slate-800">
            <div>
                <h1 class="text-xl font-bold tracking-tight text-white uppercase font-mono">
                    Tổng hợp hệ thống phần mềm SCADA - AI-VDS - PLC Block - HMI Block
                </h1>
                <p class="text-slate-400 text-xs mt-1">Giám sát tổng mặt bằng, trạng thái đỗ xe cơ khí và điều phối giao thông phân khu.</p>
            </div>
            
            <!-- Corporate Logo / Brand -->
            <div class="flex items-center gap-6 shrink-0 bg-slate-900/60 px-4 py-2 rounded-lg border border-slate-800">
                <div class="text-right">
                    <div class="text-[9px] font-mono text-slate-500 uppercase tracking-wider">PROJECT</div>
                    <div class="text-slate-200 text-xs font-extrabold uppercase font-mono leading-none tracking-widest text-emerald-400">Sora Gardens II</div>
                </div>
                <div class="w-px h-6 bg-slate-800"></div>
                <div class="text-right">
                    <div class="text-[9px] font-mono text-slate-500 uppercase tracking-wider">SYSTEM BY</div>
                    <div class="text-slate-200 text-xs font-extrabold uppercase font-mono leading-none tracking-widest text-blue-400">Total Parking</div>
                </div>
            </div>
        </div>

        <!-- Upper Control Board: Remarks (Legend) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-center bg-slate-900/40 p-4 rounded-xl border border-slate-800/40">
            <!-- Remarks -->
            <div class="flex flex-wrap items-center gap-4 text-xs font-mono">
                <span class="text-slate-500 uppercase font-semibold text-[10px] tracking-wider">REMARKS:</span>
                <div class="flex items-center gap-2 px-2.5 py-1 rounded bg-slate-800 border border-slate-700/60">
                    <span class="w-3.5 h-3.5 rounded border bg-fuchsia-600 border-fuchsia-400 inline-block shadow-[0_0_6px_rgba(240,46,170,0.4)]"></span>
                    <span class="text-slate-300 text-[10px]">PSH-7 (7 SPACES)</span>
                </div>
                <div class="flex items-center gap-2 px-2.5 py-1 rounded bg-slate-800 border border-slate-700/60">
                    <span class="w-3.5 h-3.5 rounded border bg-blue-600 border-blue-400 inline-block shadow-[0_0_6px_rgba(37,99,235,0.4)]"></span>
                    <span class="text-slate-300 text-[10px]">PSH-5 (5 SPACES)</span>
                </div>
                <div class="flex items-center gap-2 px-2.5 py-1 rounded bg-slate-800 border border-slate-700/60">
                    <span class="w-3.5 h-3.5 rounded border bg-violet-600 border-violet-400 inline-block shadow-[0_0_6px_rgba(124,58,237,0.4)]"></span>
                    <span class="text-slate-300 text-[10px]">PSH-3 (3 SPACES)</span>
                </div>
            </div>
            
            <!-- Quick System State Ticker -->
            <div class="flex items-center justify-end gap-3 text-xs font-mono text-slate-500">
                <span>Trạng thái kết nối ZCU/PGS:</span>
                <span class="inline-flex items-center gap-1 text-emerald-400 font-semibold px-2 py-0.5 rounded bg-emerald-950/40 border border-emerald-800/40">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> ONLINE
                </span>
            </div>
        </div>

        <!-- 2D Interactive CAD Map Panel -->
        <div class="relative w-full overflow-hidden rounded-xl border border-slate-800/60 bg-slate-950/80 shadow-2xl p-3 flex justify-center items-center">
            <!-- aspect ratio wrapper to maintain 1016x781 dimensions -->
            <div class="relative w-full max-w-5xl select-none" style="aspect-ratio: 1016 / 781;">
                
                <!-- Background Image (CAD drawing) -->
                <img src="@Url.Content("~/Images/zones_map.jpeg")" alt="Parking Zones Map" class="w-full h-full object-contain select-none" />

                <!-- SVG Overlay for Interactive Polygons, Pointer Lines, and Labels -->
                <svg class="absolute top-0 left-0 w-full h-full pointer-events-auto" viewBox="0 0 1016 781" xmlns="http://www.w3.org/2000/svg">
                    
                    <!-- SVG Pointer Lines connecting Callouts to Zone Centers -->
                    <!-- Line 1 (Zone 1) -->
                    <line x1="792" y1="586" x2="750" y2="550" class="pointer-line pointer-line-1" data-zone="1" />
                    <!-- Line 2 (Zone 2) -->
                    <line x1="325" y1="547" x2="450" y2="510" class="pointer-line pointer-line-2" data-zone="2" />
                    <!-- Line 3 (Zone 3) -->
                    <line x1="101" y1="117" x2="180" y2="200" class="pointer-line pointer-line-3" data-zone="3" />
                    <!-- Line 4 (Zone 4) -->
                    <line x1="488" y1="78" x2="410" y2="200" class="pointer-line pointer-line-4" data-zone="4" />
                    <!-- Line 5 (Zone 5) -->
                    <line x1="792" y1="117" x2="700" y2="140" class="pointer-line pointer-line-5" data-zone="5" />
                    <!-- Line 6 (Zone 6) -->
                    <line x1="792" y1="351" x2="750" y2="320" class="pointer-line pointer-line-6" data-zone="6" />

                    <!-- SVG Polygons for Zones (Clickable) -->
                    <!-- Zone 3 (Top Left, Orange) -->
                    <a href="@Url.Action("Zones", "Home", new { id = 3 })" class="zone-link zone-interactive" data-zone="3">
                        <polygon points="57,152 185,46 343,45 308,248 278,293 308,390" class="zone-polygon zone-3" />
                    </a>

                    <!-- Zone 4 (Top Middle, Purple) -->
                    <a href="@Url.Action("Zones", "Home", new { id = 4 })" class="zone-link zone-interactive" data-zone="4">
                        <polygon points="343,45 526,45 526,390 412,390 308,390 278,293 308,248" class="zone-polygon zone-4" />
                    </a>

                    <!-- Zone 5 (Top Right, Cyan/Blue) -->
                    <a href="@Url.Action("Zones", "Home", new { id = 5 })" class="zone-link zone-interactive" data-zone="5">
                        <polygon points="526,45 923,46 923,235 718,223 632,198 526,211" class="zone-polygon zone-5" />
                    </a>

                    <!-- Zone 6 (Middle Right, Green) -->
                    <a href="@Url.Action("Zones", "Home", new { id = 6 })" class="zone-link zone-interactive" data-zone="6">
                        <polygon points="526,211 632,198 718,223 923,235 923,410 602,410 602,380 573,380" class="zone-polygon zone-6" />
                    </a>

                    <!-- Zone 2 (Bottom Middle, Grey) -->
                    <a href="@Url.Action("Zones", "Home", new { id = 2 })" class="zone-link zone-interactive" data-zone="2">
                        <polygon points="308,390 602,390 602,510 573,510 573,630" class="zone-polygon zone-2" />
                    </a>

                    <!-- Zone 1 (Bottom Right, Yellow) -->
                    <a href="@Url.Action("Zones", "Home", new { id = 1 })" class="zone-link zone-interactive" data-zone="1">
                        <polygon points="602,410 923,410 923,582 688,748 573,630 573,510 602,510" class="zone-polygon zone-1" />
                    </a>

                    <!-- Glowing Text Labels directly on SVG for CAD look -->
                    <text x="210" y="240" class="map-label map-label-3">ZONE 3</text>
                    <text x="430" y="230" class="map-label map-label-4">ZONE 4</text>
                    <text x="700" y="120" class="map-label map-label-5">ZONE 5</text>
                    <text x="730" y="290" class="map-label map-label-6">ZONE 6</text>
                    <text x="420" y="470" class="map-label map-label-2">ZONE 2</text>
                    <text x="730" y="510" class="map-label map-label-1">ZONE 1</text>
                </svg>

                <!-- HTML Callout Boxes Overlayed on top of aspect-ratio container -->
                <!-- Callout 1 (Zone 1 - Bottom Right, Yellow) -->
                <div class="zone-callout zone-interactive" data-zone="1" style="top: 75%; left: 78%;" onclick="location.href='@Url.Action("Zones", "Home", new { id = 1 })'">
                    <div class="callout-header">ZONE 1: Vị trí trống</div>
                    <div class="callout-detail">+ SUV: 05/16</div>
                    <div class="callout-detail">+ SEDAN: 06/18</div>
                    <div class="callout-density">Mật độ: 23/34 (68%)</div>
                </div>

                <!-- Callout 2 (Zone 2 - Bottom Middle, Grey) -->
                <div class="zone-callout zone-interactive" data-zone="2" style="top: 70%; left: 32%;" onclick="location.href='@Url.Action("Zones", "Home", new { id = 2 })'">
                    <div class="callout-header">ZONE 2: Vị trí trống</div>
                    <div class="callout-detail">+ SUV: 07/16</div>
                    <div class="callout-detail">+ SEDAN: 11/22</div>
                    <div class="callout-density">Mật độ: 20/38 (53%)</div>
                </div>

                <!-- Callout 3 (Zone 3 - Top Left, Orange) -->
                <div class="zone-callout zone-interactive" data-zone="3" style="top: 15%; left: 8%;" onclick="location.href='@Url.Action("Zones", "Home", new { id = 3 })'">
                    <div class="callout-header">ZONE 3: Vị trí trống</div>
                    <div class="callout-detail">+ SUV: 12/16</div>
                    <div class="callout-detail">+ SEDAN: 18/24</div>
                    <div class="callout-density">Mật độ: 10/40 (25%)</div>
                </div>

                <!-- Callout 4 (Zone 4 - Top Middle, Purple) -->
                <div class="zone-callout zone-interactive" data-zone="4" style="top: 10%; left: 45%;" onclick="location.href='@Url.Action("Zones", "Home", new { id = 4 })'">
                    <div class="callout-header">ZONE 4: Vị trí trống</div>
                    <div class="callout-detail">+ SUV: 14/18</div>
                    <div class="callout-detail">+ SEDAN: 20/26</div>
                    <div class="callout-density">Mật độ: 10/44 (23%)</div>
                </div>

                <!-- Callout 5 (Zone 5 - Top Right, Cyan/Blue) -->
                <div class="zone-callout zone-interactive" data-zone="5" style="top: 15%; left: 78%;" onclick="location.href='@Url.Action("Zones", "Home", new { id = 5 })'">
                    <div class="callout-header">ZONE 5: Vị trí trống</div>
                    <div class="callout-detail">+ SUV: 06/12</div>
                    <div class="callout-detail">+ SEDAN: 09/18</div>
                    <div class="callout-density">Mật độ: 15/30 (50%)</div>
                </div>

                <!-- Callout 6 (Zone 6 - Middle Right, Green) -->
                <div class="zone-callout zone-interactive" data-zone="6" style="top: 45%; left: 78%;" onclick="location.href='@Url.Action("Zones", "Home", new { id = 6 })'">
                    <div class="callout-header">ZONE 6: Vị trí trống</div>
                    <div class="callout-detail">+ SUV: 04/15</div>
                    <div class="callout-detail">+ SEDAN: 06/20</div>
                    <div class="callout-density">Mật độ: 10/35 (28%)</div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Interactive CAD Map & Tooltip CSS Stylesheet -->
<style>
    /* SVG Pointer Lines */
    .pointer-line {
        stroke: rgba(148, 163, 184, 0.3);
        stroke-width: 1.5;
        stroke-dasharray: 4 4;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    /* Highlight states for lines */
    .pointer-line.active {
        stroke: #FACC15;
        stroke-width: 2.5;
        stroke-dasharray: 0;
        filter: drop-shadow(0 0 4px rgba(250, 204, 21, 0.6));
    }

    /* Interactive SVG Polygons */
    .zone-link {
        cursor: pointer;
        outline: none;
    }

    .zone-polygon {
        fill: rgba(255, 255, 255, 0);
        stroke: transparent;
        stroke-width: 2.5;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Polygons glow borders on active/hover */
    .zone-polygon.zone-1.active, .zone-polygon.zone-1:hover {
        fill: rgba(234, 179, 8, 0.15);
        stroke: rgb(234, 179, 8);
        filter: drop-shadow(0 0 8px rgba(234, 179, 8, 0.5));
    }

    .zone-polygon.zone-2.active, .zone-polygon.zone-2:hover {
        fill: rgba(148, 163, 184, 0.15);
        stroke: rgb(148, 163, 184);
        filter: drop-shadow(0 0 8px rgba(148, 163, 184, 0.5));
    }

    .zone-polygon.zone-3.active, .zone-polygon.zone-3:hover {
        fill: rgba(249, 115, 22, 0.15);
        stroke: rgb(249, 115, 22);
        filter: drop-shadow(0 0 8px rgba(249, 115, 22, 0.5));
    }

    .zone-polygon.zone-4.active, .zone-polygon.zone-4:hover {
        fill: rgba(168, 85, 247, 0.15);
        stroke: rgb(168, 85, 247);
        filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.5));
    }

    .zone-polygon.zone-5.active, .zone-polygon.zone-5:hover {
        fill: rgba(6, 182, 212, 0.15);
        stroke: rgb(6, 182, 212);
        filter: drop-shadow(0 0 8px rgba(6, 182, 212, 0.5));
    }

    .zone-polygon.zone-6.active, .zone-polygon.zone-6:hover {
        fill: rgba(34, 197, 94, 0.15);
        stroke: rgb(34, 197, 94);
        filter: drop-shadow(0 0 8px rgba(34, 197, 94, 0.5));
    }

    /* SCADA CAD Overlay Labels style */
    .map-label {
        font-family: 'Courier New', monospace;
        font-weight: bold;
        font-size: 13px;
        pointer-events: none;
        user-select: none;
        transition: all 0.3s;
    }
    
    .map-label-1 { fill: rgb(234, 179, 8); text-shadow: 0 0 4px rgba(234, 179, 8, 0.4); }
    .map-label-2 { fill: rgb(148, 163, 184); text-shadow: 0 0 4px rgba(148, 163, 184, 0.4); }
    .map-label-3 { fill: rgb(249, 115, 22); text-shadow: 0 0 4px rgba(249, 115, 22, 0.4); }
    .map-label-4 { fill: rgb(168, 85, 247); text-shadow: 0 0 4px rgba(168, 85, 247, 0.4); }
    .map-label-5 { fill: rgb(6, 182, 212); text-shadow: 0 0 4px rgba(6, 182, 212, 0.4); }
    .map-label-6 { fill: rgb(34, 197, 94); text-shadow: 0 0 4px rgba(34, 197, 94, 0.4); }

    .zone-interactive:hover .map-label {
        font-size: 15px;
    }

    /* HTML Callout Cards (Fixed absolute coordinates relative to aspect-ratio frame) */
    .zone-callout {
        position: absolute;
        width: 145px;
        padding: 8px;
        background: rgba(15, 23, 42, 0.85);
        backdrop-filter: blur(3px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 6px;
        cursor: pointer;
        user-select: none;
        z-index: 30;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
        transform: translate(-50%, -50%) scale(1);
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Callout Card Inner Typography */
    .callout-header {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        color: #94A3B8;
        border-b: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 3px;
        margin-bottom: 4px;
        letter-spacing: 0.05em;
    }

    .callout-detail {
        font-size: 9px;
        font-family: monospace;
        color: #CBD5E1;
        line-height: 1.3;
    }

    .callout-density {
        font-size: 9px;
        font-weight: 700;
        margin-top: 4px;
        padding-top: 3px;
        border-t: 1px solid rgba(255, 255, 255, 0.06);
        color: #38BDF8;
    }

    /* Callout Card Active / Hover (Yellow Mockup Style) */
    .zone-callout.active, .zone-callout:hover {
        background: rgb(250, 204, 21);
        border: 2px solid rgb(15, 23, 42);
        color: rgb(15, 23, 42);
        transform: translate(-50%, -50%) scale(1.08);
        box-shadow: 0 10px 25px rgba(250, 204, 21, 0.6);
        z-index: 40;
    }

    .zone-callout.active .callout-header, .zone-callout:hover .callout-header {
        color: rgb(15, 23, 42);
        font-weight: 900;
        border-b-color: rgba(15, 23, 42, 0.25);
    }

    .zone-callout.active .callout-detail, .zone-callout:hover .callout-detail {
        color: rgb(15, 23, 42);
        font-weight: 600;
    }

    .zone-callout.active .callout-density, .zone-callout:hover .callout-density {
        color: rgb(15, 23, 42);
        font-weight: 900;
        border-t-color: rgba(15, 23, 42, 0.15);
    }
</style>

<!-- Javascript for Bidirectional Highlight Event Handling -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const interactives = document.querySelectorAll(".zone-interactive");

        interactives.forEach(elem => {
            elem.addEventListener("mouseenter", function () {
                const zone = this.getAttribute("data-zone");
                highlightZone(zone, true);
            });

            elem.addEventListener("mouseleave", function () {
                const zone = this.getAttribute("data-zone");
                highlightZone(zone, false);
            });
        });

        function highlightZone(zoneId, isActive) {
            const polygon = document.querySelector(`.zone-polygon.zone-${zoneId}`);
            const callout = document.querySelector(`.zone-callout[data-zone="${zoneId}"]`);
            const line = document.querySelector(`.pointer-line-${zoneId}`);
            const mapLabel = document.querySelector(`.map-label-${zoneId}`);

            if (isActive) {
                if (polygon) polygon.classList.add("active");
                if (callout) callout.classList.add("active");
                if (line) line.classList.add("active");
                if (mapLabel) mapLabel.style.fontSize = "16px";
            } else {
                if (polygon) polygon.classList.remove("active");
                if (callout) callout.classList.remove("active");
                if (line) line.classList.remove("active");
                if (mapLabel) mapLabel.style.fontSize = "13px";
            }
        }
    });
</script>