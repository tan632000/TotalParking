                                        <span class="text-slate-100 text-sm font-bold font-mono tracking-wider">30H-88877</span>
                                        <span class="text-slate-500 text-xs font-mono">Cao: 1.45m · Dài: 4.20m</span>
                                    </div>
                                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-2 text-xs font-mono text-slate-400">
                                        <span>Đề xuất:</span>
                                        <span class="text-blue-300 font-bold bg-slate-800 px-1.5 py-0.5 rounded">Block B-01</span>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
